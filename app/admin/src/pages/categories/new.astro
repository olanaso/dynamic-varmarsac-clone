---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { api } from '../../lib/api';

const token = Astro.cookies.get('barmar_token')?.value ?? '';
let error = '';
let values = { name: '', description: '' };

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  values.name = (form.get('name') as string) ?? '';
  values.description = (form.get('description') as string) ?? '';

  const res = await api.post(
    '/api/admin/categories',
    { name: values.name, description: values.description },
    token,
  );

  if (res.ok) {
    return Astro.redirect('/categories');
  } else {
    const data = await res.json().catch(() => ({}));
    error = (data as any).message ?? 'No se pudo crear la categoría.';
  }
}
---
<AdminLayout title="Nueva categoría">
  <div class="max-w-lg">
    <div class="mb-6">
      <a href="/categories" class="inline-flex items-center gap-1.5 text-sm text-slate-500 hover:text-slate-700 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Volver a categorías
      </a>
    </div>

    <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-8">
      {error && (
        <div class="mb-5 flex items-center gap-3 bg-red-50 border border-red-200 text-red-700 rounded-lg px-4 py-3 text-sm">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          {error}
        </div>
      )}

      <form method="POST" class="space-y-5">
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1.5" for="name">
            Nombre <span class="text-red-500">*</span>
          </label>
          <input
            id="name"
            name="name"
            type="text"
            required
            value={values.name}
            class="w-full px-3.5 py-2.5 border border-slate-300 rounded-lg text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent"
            placeholder="Ej. Sedán"
          />
        </div>

        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1.5" for="description">
            Descripción
          </label>
          <textarea
            id="description"
            name="description"
            rows="3"
            class="w-full px-3.5 py-2.5 border border-slate-300 rounded-lg text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent resize-none"
            placeholder="Descripción opcional de la categoría"
          >{values.description}</textarea>
        </div>

        <div class="flex items-center gap-3 pt-2">
          <button
            type="submit"
            id="btn-submit"
            class="bg-primary-600 hover:bg-primary-700 text-white text-sm font-semibold px-6 py-2.5 rounded-lg transition-colors"
          >
            Crear categoría
          </button>
          <a
            href="/categories"
            class="text-sm font-medium text-slate-600 hover:text-slate-800 transition-colors"
          >
            Cancelar
          </a>
        </div>
      </form>
    </div>
  </div>
</AdminLayout>

<script is:inline>
  (function () {
    var form = document.querySelector('form[method="POST"]');
    if (!form) return;
    form.addEventListener('submit', function () {
      var btn = document.getElementById('btn-submit');
      if (!btn) return;
      if (!document.getElementById('_bspin')) {
        var s = document.createElement('style');
        s.id = '_bspin';
        s.textContent = '@keyframes _bspin{to{transform:rotate(360deg)}}';
        document.head.appendChild(s);
      }
      btn.disabled = true;
      btn.style.opacity = '0.7';
      btn.style.cursor = 'not-allowed';
      btn.innerHTML =
        '<svg style="display:inline-block;width:1rem;height:1rem;margin-right:0.4rem;vertical-align:-0.175em;animation:_bspin 1s linear infinite" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle style="opacity:.25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path style="opacity:.75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>Creando…';
    });
  })();
</script>
