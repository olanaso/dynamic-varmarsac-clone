---
import AdminLayout from '../../layouts/AdminLayout.astro';
import Dialog from '../../components/Dialog.astro';
---
<AdminLayout title="Conductores">

  <div class="flex items-center justify-between mb-6">
    <p id="cond-count" class="text-sm text-slate-500">Cargando…</p>
    <button
      type="button"
      onclick="document.getElementById('dlg-create').showModal()"
      class="inline-flex items-center gap-2 bg-primary-600 hover:bg-primary-700 text-white text-sm font-semibold px-4 py-2.5 rounded-lg transition-colors"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
      </svg>
      Nuevo conductor
    </button>
  </div>

  <div id="cond-flash" class="hidden mb-5 flex items-center gap-3 rounded-xl px-4 py-3 text-sm border"></div>

  <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
    <div id="cond-empty" class="hidden flex flex-col items-center justify-center py-16 text-slate-400">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
      </svg>
      <p class="text-sm font-medium">No hay conductores</p>
      <p class="text-xs mt-1">Crea el primero para comenzar.</p>
    </div>

    <div id="cond-table-wrap" class="hidden overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-slate-50 border-b border-slate-200">
            <th class="text-left px-6 py-3.5 font-semibold text-slate-600 whitespace-nowrap">Nombre</th>
            <th class="text-left px-6 py-3.5 font-semibold text-slate-600 whitespace-nowrap">N° Documento</th>
            <th class="text-left px-6 py-3.5 font-semibold text-slate-600 whitespace-nowrap">Celular</th>
            <th class="text-left px-6 py-3.5 font-semibold text-slate-600 whitespace-nowrap">Asignación activa</th>
            <th class="text-right px-6 py-3.5 font-semibold text-slate-600 whitespace-nowrap">Acciones</th>
          </tr>
        </thead>
        <tbody id="cond-tbody" class="divide-y divide-slate-100"></tbody>
      </table>
    </div>
  </div>

  <!-- ═══ Create dialog ══════════════════════════════════════════════════ -->
  <Dialog id="dlg-create" title="Nuevo conductor">
    <div id="create-error" class="hidden mb-4 flex items-center gap-2 bg-red-50 border border-red-200 text-red-700 rounded-lg px-3 py-2.5 text-sm"></div>
    <form id="form-create" class="space-y-4">
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1.5" for="c-nombre">
          Nombre completo <span class="text-red-500">*</span>
        </label>
        <input id="c-nombre" name="nombre_completo" type="text" required placeholder="Ej. Juan Pérez"
          class="w-full px-3.5 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500" />
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1.5" for="c-doc">
          N° Documento <span class="text-red-500">*</span>
        </label>
        <input id="c-doc" name="numero_documento" type="text" required placeholder="Ej. 12345678"
          class="w-full px-3.5 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500" />
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1.5" for="c-cel">
          Celular <span class="text-slate-400 font-normal text-xs">(opcional)</span>
        </label>
        <input id="c-cel" name="celular" type="text" placeholder="Ej. 999888777"
          class="w-full px-3.5 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500" />
      </div>
      <div class="flex items-center justify-between pt-4 border-t border-slate-100">
        <button type="button" onclick="document.getElementById('dlg-create').close()"
          class="text-sm font-medium text-slate-600 hover:text-slate-800 transition-colors">Cancelar</button>
        <button type="submit"
          class="bg-primary-600 hover:bg-primary-700 text-white text-sm font-semibold px-5 py-2.5 rounded-lg transition-colors">
          Crear conductor
        </button>
      </div>
    </form>
  </Dialog>

  <!-- ═══ Edit dialog ════════════════════════════════════════════════════ -->
  <Dialog id="dlg-edit" title="Editar conductor">
    <div id="edit-error" class="hidden mb-4 flex items-center gap-2 bg-red-50 border border-red-200 text-red-700 rounded-lg px-3 py-2.5 text-sm"></div>
    <form id="form-edit" class="space-y-4">
      <input type="hidden" id="edit-id" />
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1.5" for="e-nombre">
          Nombre completo <span class="text-red-500">*</span>
        </label>
        <input id="e-nombre" name="nombre_completo" type="text" required
          class="w-full px-3.5 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500" />
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1.5" for="e-doc">
          N° Documento <span class="text-red-500">*</span>
        </label>
        <input id="e-doc" name="numero_documento" type="text" required
          class="w-full px-3.5 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500" />
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1.5" for="e-cel">
          Celular <span class="text-slate-400 font-normal text-xs">(opcional)</span>
        </label>
        <input id="e-cel" name="celular" type="text"
          class="w-full px-3.5 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500" />
      </div>
      <div class="flex items-center justify-between pt-4 border-t border-slate-100">
        <button type="button" onclick="document.getElementById('dlg-edit').close()"
          class="text-sm font-medium text-slate-600 hover:text-slate-800 transition-colors">Cancelar</button>
        <button type="submit"
          class="bg-primary-600 hover:bg-primary-700 text-white text-sm font-semibold px-5 py-2.5 rounded-lg transition-colors">
          Guardar cambios
        </button>
      </div>
    </form>
  </Dialog>

  <!-- ═══ Assign vehicle dialog ══════════════════════════════════════════ -->
  <Dialog id="dlg-asignar" title="Asignar vehículo">
    <div id="asignar-error" class="hidden mb-4 flex items-center gap-2 bg-red-50 border border-red-200 text-red-700 rounded-lg px-3 py-2.5 text-sm"></div>
    <form id="form-asignar" class="space-y-4">
      <input type="hidden" id="asignar-conductor-id" />
      <div class="bg-slate-50 border border-slate-200 rounded-lg px-4 py-2.5">
        <p class="text-xs text-slate-500">Conductor</p>
        <p id="asignar-conductor-name" class="text-sm font-semibold text-slate-800"></p>
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1.5">
          Vehículo <span class="text-red-500">*</span>
        </label>
        <div id="asignar-vehiculo-wrap"></div>
      </div>
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1.5" for="asignar-inicio">
            Fecha inicio <span class="text-red-500">*</span>
          </label>
          <input id="asignar-inicio" type="date" required
            class="w-full px-3.5 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500" />
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1.5" for="asignar-limite">
            Fecha límite <span class="text-red-500">*</span>
          </label>
          <input id="asignar-limite" type="date" required
            class="w-full px-3.5 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500" />
        </div>
      </div>
      <div class="flex items-center justify-between pt-4 border-t border-slate-100">
        <button type="button" onclick="document.getElementById('dlg-asignar').close()"
          class="text-sm font-medium text-slate-600 hover:text-slate-800 transition-colors">Cancelar</button>
        <button type="submit"
          class="bg-primary-600 hover:bg-primary-700 text-white text-sm font-semibold px-5 py-2.5 rounded-lg transition-colors">
          Asignar
        </button>
      </div>
    </form>
  </Dialog>

  <!-- ═══ History dialog ════════════════════════════════════════════════ -->
  <Dialog id="dlg-historial" title="Historial de asignaciones" size="lg">
    <div id="historial-conductor-info" class="mb-4 bg-slate-50 border border-slate-200 rounded-lg px-4 py-2.5">
      <p class="text-xs text-slate-500">Conductor</p>
      <p id="historial-conductor-name" class="text-sm font-semibold text-slate-800"></p>
    </div>
    <div id="historial-empty" class="hidden py-10 text-center text-slate-400">
      <p class="text-sm">Sin asignaciones registradas.</p>
    </div>
    <div id="historial-table-wrap" class="hidden overflow-x-auto rounded-lg border border-slate-200">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-slate-50 border-b border-slate-200">
            <th class="text-left px-4 py-3 font-semibold text-slate-600 whitespace-nowrap">Vehículo</th>
            <th class="text-left px-4 py-3 font-semibold text-slate-600 whitespace-nowrap">Inicio</th>
            <th class="text-left px-4 py-3 font-semibold text-slate-600 whitespace-nowrap">Límite</th>
            <th class="text-left px-4 py-3 font-semibold text-slate-600 whitespace-nowrap">Estado</th>
            <th class="text-right px-4 py-3 font-semibold text-slate-600 whitespace-nowrap">Acciones</th>
          </tr>
        </thead>
        <tbody id="historial-tbody" class="divide-y divide-slate-100"></tbody>
      </table>
    </div>
    <div class="pt-4 border-t border-slate-100 flex justify-end">
      <button type="button" onclick="document.getElementById('dlg-historial').close()"
        class="text-sm font-medium text-slate-600 hover:text-slate-800 transition-colors px-4 py-2">Cerrar</button>
    </div>
  </Dialog>

  <!-- ═══ Delete dialog ════════════════════════════════════════════════ -->
  <Dialog id="dlg-delete" title="Eliminar conductor" size="sm">
    <input type="hidden" id="delete-id" />
    <div class="flex items-start gap-4 mb-6">
      <div class="w-10 h-10 rounded-full bg-red-100 flex items-center justify-center shrink-0">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
        </svg>
      </div>
      <div>
        <p class="text-sm font-medium text-slate-800">¿Eliminar este conductor?</p>
        <p class="text-sm text-slate-500 mt-1">
          <strong id="delete-nombre" class="text-slate-700"></strong> será eliminado. Esta acción no se puede deshacer.
        </p>
      </div>
    </div>
    <div class="flex items-center justify-end gap-3">
      <button type="button" onclick="document.getElementById('dlg-delete').close()"
        class="text-sm font-medium text-slate-600 hover:text-slate-800 transition-colors px-4 py-2">Cancelar</button>
      <button type="button" id="btn-delete-confirm"
        class="bg-red-600 hover:bg-red-700 text-white text-sm font-semibold px-5 py-2.5 rounded-lg transition-colors">
        Sí, eliminar
      </button>
    </div>
  </Dialog>

</AdminLayout>

<script is:inline>
  (function () {
    function esc(s) {
      if (s == null) return '';
      return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/"/g, '&quot;');
    }

    function setLoading(btn, isLoading, text) {
      if (!btn) return;
      if (isLoading) {
        if (!document.getElementById('_bspin')) {
          var s = document.createElement('style');
          s.id = '_bspin';
          s.textContent = '@keyframes _bspin{to{transform:rotate(360deg)}}';
          document.head.appendChild(s);
        }
        btn._origHTML = btn.innerHTML;
        btn.disabled = true;
        btn.style.opacity = '0.7';
        btn.style.cursor = 'not-allowed';
        btn.innerHTML =
          '<svg style="display:inline-block;width:1rem;height:1rem;margin-right:0.4rem;vertical-align:-0.175em;animation:_bspin 1s linear infinite" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle style="opacity:.25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path style="opacity:.75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>' +
          (text || 'Procesando…');
      } else {
        btn.disabled = false;
        btn.style.opacity = '';
        btn.style.cursor = '';
        if (btn._origHTML !== undefined) btn.innerHTML = btn._origHTML;
      }
    }

    function showFlash(msg, type) {
      var el = document.getElementById('cond-flash');
      if (!msg) { el.classList.add('hidden'); return; }
      el.classList.remove('hidden');
      el.className =
        'mb-5 flex items-center gap-3 rounded-xl px-4 py-3 text-sm border ' +
        (type === 'error'
          ? 'bg-red-50 border-red-200 text-red-700'
          : 'bg-green-50 border-green-200 text-green-700');
      el.textContent = msg;
    }

    function fmtDate(iso) {
      if (!iso) return '—';
      var parts = String(iso).split('T')[0].split('-');
      var months = ['ene','feb','mar','abr','may','jun','jul','ago','sep','oct','nov','dic'];
      return parts[2] + ' ' + months[parseInt(parts[1], 10) - 1] + ' ' + parts[0];
    }

    // ── State ──────────────────────────────────────────────────────────────
    var _conductores = [];
    var _activeAsig  = []; // all active assignments loaded once

    function isActiveToday(conductorId) {
      var today = new Date().toISOString().split('T')[0];
      return _activeAsig.find(function (a) {
        return String(a.conductor_id) === String(conductorId) &&
               a.fecha_inicio <= today && a.fecha_limite >= today;
      });
    }

    function renderRows(list) {
      var tbody = document.getElementById('cond-tbody');
      var empty = document.getElementById('cond-empty');
      var wrap  = document.getElementById('cond-table-wrap');
      var count = document.getElementById('cond-count');

      count.textContent = list.length + ' conductor' + (list.length !== 1 ? 'es' : '') + ' en total';

      if (list.length === 0) {
        empty.classList.remove('hidden');
        wrap.classList.add('hidden');
        tbody.innerHTML = '';
        return;
      }
      empty.classList.add('hidden');
      wrap.classList.remove('hidden');

      tbody.innerHTML = list.map(function (c) {
        var asig = isActiveToday(c.id);
        var asigCell = asig
          ? '<span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-blue-100 text-blue-700">' +
            '<span class="w-1.5 h-1.5 rounded-full bg-blue-500"></span>' +
            esc(asig.vehicle ? asig.vehicle.name : 'Vehículo') + '</span>' +
            (asig.vehicle && asig.vehicle.registration_number
              ? ' <span class="text-xs text-slate-400 font-normal">' + esc(asig.vehicle.registration_number) + '</span>'
              : '')
          : '<span class="text-slate-400 text-xs">—</span>';

        return (
          '<tr class="hover:bg-slate-50/50 transition-colors">' +
          '<td class="px-6 py-4 font-medium text-slate-800 whitespace-nowrap">' + esc(c.nombre_completo) + '</td>' +
          '<td class="px-6 py-4 text-slate-600 whitespace-nowrap">' + esc(c.numero_documento) + '</td>' +
          '<td class="px-6 py-4 text-slate-500 whitespace-nowrap">' + (esc(c.celular) || '—') + '</td>' +
          '<td class="px-6 py-4">' + asigCell + '</td>' +
          '<td class="px-6 py-4">' +
          '<div class="flex items-center justify-end gap-2">' +
          '<button type="button" class="text-xs px-3 py-1.5 rounded-lg border border-slate-200 text-slate-600 hover:bg-slate-50 transition-colors" ' +
          'data-id="' + c.id + '" data-nombre="' + esc(c.nombre_completo) + '" data-doc="' + esc(c.numero_documento) + '" data-cel="' + esc(c.celular) + '" ' +
          'onclick="openEditDialog(this)">Editar</button>' +
          '<button type="button" class="text-xs px-3 py-1.5 rounded-lg border border-primary-200 text-primary-600 hover:bg-primary-50 transition-colors" ' +
          'data-id="' + c.id + '" data-nombre="' + esc(c.nombre_completo) + '" ' +
          'onclick="openAsignarDialog(this)">Asignar vehículo</button>' +
          '<button type="button" class="text-xs px-3 py-1.5 rounded-lg border border-slate-200 text-slate-600 hover:bg-slate-50 transition-colors" ' +
          'data-id="' + c.id + '" data-nombre="' + esc(c.nombre_completo) + '" ' +
          'onclick="openHistorialDialog(this)">Historial</button>' +
          '<button type="button" class="text-xs px-3 py-1.5 rounded-lg border border-red-200 text-red-600 hover:bg-red-50 transition-colors" ' +
          'data-id="' + c.id + '" data-nombre="' + esc(c.nombre_completo) + '" ' +
          'onclick="openDeleteDialog(this)">Eliminar</button>' +
          '</div></td></tr>'
        );
      }).join('');
    }

    window.loadConductores = function () {
      var p1 = window.barmarAuthFetch('/api/admin/conductores')
        .then(function (r) { return r.json(); })
        .then(function (j) { _conductores = j.data || []; });
      var p2 = window.barmarAuthFetch('/api/admin/asignaciones?estado=activa')
        .then(function (r) { return r.json(); })
        .then(function (j) { _activeAsig = j.data || []; });
      return Promise.all([p1, p2])
        .then(function () { renderRows(_conductores); });
    };

    window.openEditDialog = function (btn) {
      document.getElementById('edit-id').value    = btn.dataset.id;
      document.getElementById('e-nombre').value   = btn.dataset.nombre || '';
      document.getElementById('e-doc').value      = btn.dataset.doc || '';
      document.getElementById('e-cel').value      = btn.dataset.cel || '';
      document.getElementById('edit-error').classList.add('hidden');
      document.getElementById('dlg-edit').showModal();
    };

    window.openDeleteDialog = function (btn) {
      document.getElementById('delete-id').value          = btn.dataset.id;
      document.getElementById('delete-nombre').textContent = btn.dataset.nombre;
      document.getElementById('dlg-delete').showModal();
    };

    // ── Asignar vehículo dialog ────────────────────────────────────────────
    var _vehiclesCache = null;
    var _asignarVehicleSelect = null;

    window.openAsignarDialog = function (btn) {
      document.getElementById('asignar-conductor-id').value        = btn.dataset.id;
      document.getElementById('asignar-conductor-name').textContent = btn.dataset.nombre;
      document.getElementById('asignar-error').classList.add('hidden');

      var today = new Date().toISOString().split('T')[0];
      document.getElementById('asignar-inicio').value = today;
      document.getElementById('asignar-limite').value = today;

      // Init searchable select once
      if (!_asignarVehicleSelect) {
        _asignarVehicleSelect = new window.SearchableSelect(
          document.getElementById('asignar-vehiculo-wrap'),
          'Buscar vehículo…'
        );
      } else {
        _asignarVehicleSelect.reset();
      }

      var fetchVehicles = _vehiclesCache
        ? Promise.resolve(_vehiclesCache)
        : window.barmarAuthFetch('/api/admin/vehicles?limit=200')
            .then(function (r) { return r.json(); })
            .then(function (j) { _vehiclesCache = j.data || []; return _vehiclesCache; });

      fetchVehicles.then(function (vehicles) {
        _asignarVehicleSelect.setOptions(vehicles.map(function (v) {
          return { value: v.id, label: v.name + ' · ' + v.registration_number };
        }));
      });

      document.getElementById('dlg-asignar').showModal();
    };

    // ── Historial dialog ──────────────────────────────────────────────────
    window.openHistorialDialog = function (btn) {
      document.getElementById('historial-conductor-name').textContent = btn.dataset.nombre;
      var tbody  = document.getElementById('historial-tbody');
      var empty  = document.getElementById('historial-empty');
      var wrap   = document.getElementById('historial-table-wrap');
      tbody.innerHTML = '<tr><td colspan="5" class="px-4 py-8 text-center text-slate-400 text-sm">Cargando…</td></tr>';
      empty.classList.add('hidden');
      wrap.classList.remove('hidden');
      document.getElementById('dlg-historial').showModal();

      window.barmarAuthFetch('/api/admin/asignaciones?conductor_id=' + btn.dataset.id)
        .then(function (r) { return r.json(); })
        .then(function (j) {
          var list = j.data || [];
          if (list.length === 0) {
            wrap.classList.add('hidden');
            empty.classList.remove('hidden');
            return;
          }
          wrap.classList.remove('hidden');
          empty.classList.add('hidden');
          tbody.innerHTML = list.map(function (a) {
            var vname = a.vehicle ? (esc(a.vehicle.name) + ' <span class="text-slate-400">(' + esc(a.vehicle.registration_number) + ')</span>') : '—';
            var estadoCls = a.estado === 'activa'
              ? 'bg-green-100 text-green-700'
              : 'bg-slate-100 text-slate-500';
            var estadoLabel = a.estado === 'activa' ? 'Activa' : 'Cancelada';
            var acciones = a.estado === 'activa'
              ? '<button type="button" class="text-xs px-2.5 py-1 rounded-lg border border-amber-200 text-amber-700 hover:bg-amber-50 transition-colors" onclick="cancelarAsig(' + a.id + ', this)">Cancelar</button> '
              : '';
            acciones += '<button type="button" class="text-xs px-2.5 py-1 rounded-lg border border-red-200 text-red-600 hover:bg-red-50 transition-colors" onclick="eliminarAsig(' + a.id + ', this)">Eliminar</button>';
            return (
              '<tr class="hover:bg-slate-50/50">' +
              '<td class="px-4 py-3 text-slate-700">' + vname + '</td>' +
              '<td class="px-4 py-3 text-slate-500 whitespace-nowrap text-xs">' + fmtDate(a.fecha_inicio) + '</td>' +
              '<td class="px-4 py-3 text-slate-500 whitespace-nowrap text-xs">' + fmtDate(a.fecha_limite) + '</td>' +
              '<td class="px-4 py-3"><span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold ' + estadoCls + '">' + estadoLabel + '</span></td>' +
              '<td class="px-4 py-3 text-right whitespace-nowrap">' + acciones + '</td>' +
              '</tr>'
            );
          }).join('');
        })
        .catch(function () {
          tbody.innerHTML = '<tr><td colspan="5" class="px-4 py-6 text-center text-red-500 text-sm">Error al cargar.</td></tr>';
        });
    };

    window.cancelarAsig = function (id, btn) {
      setLoading(btn, true, 'Cancelando…');
      window.barmarAuthFetch('/api/admin/asignaciones/' + id + '/cancelar', { method: 'PATCH' })
        .then(function (r) { return r.json().then(function (d) { return { ok: r.ok, data: d }; }); })
        .then(function (x) {
          setLoading(btn, false);
          if (!x.ok) { showFlash(x.data.message || 'Error.', 'error'); return; }
          showFlash('Asignación cancelada.', 'success');
          window.loadConductores();
          // refresh historial rows
          var row = btn.closest('tr');
          if (row) {
            var cells = row.querySelectorAll('td');
            if (cells[3]) cells[3].innerHTML = '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-slate-100 text-slate-500">Cancelada</span>';
            if (cells[4]) cells[4].innerHTML = '<button type="button" class="text-xs px-2.5 py-1 rounded-lg border border-red-200 text-red-600 hover:bg-red-50 transition-colors" onclick="eliminarAsig(' + id + ', this)">Eliminar</button>';
          }
        })
        .catch(function () { setLoading(btn, false); showFlash('Error de red.', 'error'); });
    };

    window.eliminarAsig = function (id, btn) {
      if (!confirm('¿Eliminar esta asignación permanentemente?')) return;
      setLoading(btn, true, 'Eliminando…');
      window.barmarAuthFetch('/api/admin/asignaciones/' + id, { method: 'DELETE' })
        .then(function (r) { return r.json().then(function (d) { return { ok: r.ok, data: d }; }); })
        .then(function (x) {
          setLoading(btn, false);
          if (!x.ok) { showFlash(x.data.message || 'Error.', 'error'); return; }
          showFlash('Asignación eliminada.', 'success');
          window.loadConductores();
          var row = btn.closest('tr');
          if (row) row.remove();
        })
        .catch(function () { setLoading(btn, false); showFlash('Error de red.', 'error'); });
    };

    function init() {
      /* ── Create ── */
      document.getElementById('form-create').addEventListener('submit', function (e) {
        e.preventDefault();
        var err = document.getElementById('create-error');
        err.classList.add('hidden');
        var btn = e.currentTarget.querySelector('[type="submit"]');
        setLoading(btn, true, 'Creando…');
        window.barmarAuthFetch('/api/admin/conductores', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            nombre_completo: document.getElementById('c-nombre').value,
            numero_documento: document.getElementById('c-doc').value,
            celular: document.getElementById('c-cel').value || null,
          }),
        })
          .then(function (r) { return r.json().then(function (d) { return { ok: r.ok, data: d }; }); })
          .then(function (x) {
            setLoading(btn, false);
            if (!x.ok) {
              var msgs = x.data.errors ? x.data.errors.map(function (e) { return e.message; }).join(' · ') : (x.data.message || 'No se pudo crear.');
              err.textContent = msgs;
              err.classList.remove('hidden');
              return;
            }
            document.getElementById('dlg-create').close();
            document.getElementById('form-create').reset();
            showFlash('Conductor creado correctamente.', 'success');
            return window.loadConductores();
          })
          .catch(function () { setLoading(btn, false); err.textContent = 'Error de red.'; err.classList.remove('hidden'); });
      });

      /* ── Edit ── */
      document.getElementById('form-edit').addEventListener('submit', function (e) {
        e.preventDefault();
        var err = document.getElementById('edit-error');
        err.classList.add('hidden');
        var btn = e.currentTarget.querySelector('[type="submit"]');
        var id = document.getElementById('edit-id').value;
        setLoading(btn, true, 'Guardando…');
        window.barmarAuthFetch('/api/admin/conductores/' + id, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            nombre_completo: document.getElementById('e-nombre').value,
            numero_documento: document.getElementById('e-doc').value,
            celular: document.getElementById('e-cel').value || null,
          }),
        })
          .then(function (r) { return r.json().then(function (d) { return { ok: r.ok, data: d }; }); })
          .then(function (x) {
            setLoading(btn, false);
            if (!x.ok) {
              var msgs = x.data.errors ? x.data.errors.map(function (e) { return e.message; }).join(' · ') : (x.data.message || 'No se pudo actualizar.');
              err.textContent = msgs;
              err.classList.remove('hidden');
              return;
            }
            document.getElementById('dlg-edit').close();
            showFlash('Conductor actualizado.', 'success');
            return window.loadConductores();
          })
          .catch(function () { setLoading(btn, false); err.textContent = 'Error de red.'; err.classList.remove('hidden'); });
      });

      /* ── Asignar vehículo ── */
      document.getElementById('form-asignar').addEventListener('submit', function (e) {
        e.preventDefault();
        var err = document.getElementById('asignar-error');
        err.classList.add('hidden');
        var btn = e.currentTarget.querySelector('[type="submit"]');
        var conductorId = document.getElementById('asignar-conductor-id').value;
        var vehicleId   = _asignarVehicleSelect ? _asignarVehicleSelect.getValue() : '';
        var inicio      = document.getElementById('asignar-inicio').value;
        var limite      = document.getElementById('asignar-limite').value;
        if (!vehicleId) { err.textContent = 'Selecciona un vehículo.'; err.classList.remove('hidden'); return; }
        setLoading(btn, true, 'Asignando…');
        window.barmarAuthFetch('/api/admin/asignaciones', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ conductor_id: Number(conductorId), vehicle_id: Number(vehicleId), fecha_inicio: inicio, fecha_limite: limite }),
        })
          .then(function (r) { return r.json().then(function (d) { return { ok: r.ok, data: d }; }); })
          .then(function (x) {
            setLoading(btn, false);
            if (!x.ok) {
              var msgs = x.data.errors ? x.data.errors.map(function (e) { return e.message; }).join(' · ') : (x.data.message || 'No se pudo asignar.');
              err.textContent = msgs;
              err.classList.remove('hidden');
              return;
            }
            document.getElementById('dlg-asignar').close();
            showFlash('Vehículo asignado correctamente.', 'success');
            return window.loadConductores();
          })
          .catch(function () { setLoading(btn, false); err.textContent = 'Error de red.'; err.classList.remove('hidden'); });
      });

      /* ── Delete ── */
      document.getElementById('btn-delete-confirm').addEventListener('click', function () {
        var btn = document.getElementById('btn-delete-confirm');
        var id  = document.getElementById('delete-id').value;
        setLoading(btn, true, 'Eliminando…');
        window.barmarAuthFetch('/api/admin/conductores/' + id, { method: 'DELETE' })
          .then(function (r) { return r.json().then(function (d) { return { ok: r.ok, data: d }; }); })
          .then(function (x) {
            setLoading(btn, false);
            document.getElementById('dlg-delete').close();
            if (!x.ok) { showFlash(x.data.message || 'No se pudo eliminar.', 'error'); return; }
            showFlash('Conductor eliminado.', 'success');
            return window.loadConductores();
          })
          .catch(function () { setLoading(btn, false); showFlash('Error de red.', 'error'); });
      });

      window.loadConductores().catch(function () {
        document.getElementById('cond-count').textContent = 'No se pudieron cargar los conductores';
        showFlash('No se pudo conectar con el backend.', 'error');
      });
    }

    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
    else init();
  })();
</script>
