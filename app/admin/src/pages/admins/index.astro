---
import AdminLayout from '../../layouts/AdminLayout.astro';
import Dialog from '../../components/Dialog.astro';
---
<AdminLayout title="Administrativos">

  <div class="flex items-center justify-between mb-6">
    <p id="adm-count" class="text-sm text-slate-500">Cargando…</p>
    <button
      type="button"
      onclick="document.getElementById('dlg-create').showModal()"
      class="inline-flex items-center gap-2 bg-primary-600 hover:bg-primary-700 text-white text-sm font-semibold px-4 py-2.5 rounded-lg transition-colors"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
      </svg>
      Nuevo administrador
    </button>
  </div>

  <div id="adm-flash" class="hidden mb-5 flex items-center gap-3 rounded-xl px-4 py-3 text-sm border"></div>

  <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
    <div id="adm-empty" class="hidden flex flex-col items-center justify-center py-16 text-slate-400">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
      </svg>
      <p class="text-sm font-medium">No hay administradores</p>
      <p class="text-xs mt-1">Crea el primero para comenzar.</p>
    </div>

    <div id="adm-table-wrap" class="hidden overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-slate-50 border-b border-slate-200">
            <th class="text-left px-6 py-3.5 font-semibold text-slate-600 whitespace-nowrap">Nombre</th>
            <th class="text-left px-6 py-3.5 font-semibold text-slate-600 whitespace-nowrap">Email</th>
            <th class="text-left px-6 py-3.5 font-semibold text-slate-600 whitespace-nowrap">N° Documento</th>
            <th class="text-left px-6 py-3.5 font-semibold text-slate-600 whitespace-nowrap">Celular</th>
            <th class="text-left px-6 py-3.5 font-semibold text-slate-600 whitespace-nowrap">Estado</th>
            <th class="text-left px-6 py-3.5 font-semibold text-slate-600 whitespace-nowrap">Fecha de alta</th>
            <th class="text-right px-6 py-3.5 font-semibold text-slate-600 whitespace-nowrap">Acciones</th>
          </tr>
        </thead>
        <tbody id="adm-tbody" class="divide-y divide-slate-100"></tbody>
      </table>
    </div>
  </div>

  <!-- Create dialog -->
  <Dialog id="dlg-create" title="Nuevo administrador" size="lg">
    <div id="create-error" class="hidden mb-4 flex items-center gap-2 bg-red-50 border border-red-200 text-red-700 rounded-lg px-3 py-2.5 text-sm"></div>
    <form id="form-create" class="space-y-4">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1.5" for="c-nombre">
            Nombres y apellidos <span class="text-red-500">*</span>
          </label>
          <input id="c-nombre" name="nombre_completo" type="text" required placeholder="Ej. Juan Pérez"
            class="w-full px-3.5 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500" />
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1.5" for="c-documento">
            N° Documento <span class="text-red-500">*</span>
          </label>
          <input id="c-documento" name="numero_documento" type="text" required placeholder="Ej. 12345678"
            class="w-full px-3.5 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500" />
        </div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1.5" for="c-email">
            Email <span class="text-red-500">*</span>
          </label>
          <input id="c-email" name="email" type="email" required placeholder="admin@empresa.com"
            class="w-full px-3.5 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500" />
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1.5" for="c-celular">
            Celular <span class="text-slate-400 font-normal text-xs">(opcional)</span>
          </label>
          <input id="c-celular" name="celular" type="text" placeholder="Ej. 999888777"
            class="w-full px-3.5 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500" />
        </div>
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1.5" for="c-password">
          Contraseña <span class="text-red-500">*</span>
        </label>
        <input id="c-password" name="password" type="password" required minlength="6"
          placeholder="Mínimo 6 caracteres"
          class="w-full px-3.5 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500" />
      </div>
      <div class="flex items-center gap-3">
        <input id="c-active" name="is_active" type="checkbox" checked
          class="w-4 h-4 rounded border-slate-300 text-primary-600 focus:ring-primary-500" />
        <label for="c-active" class="text-sm font-medium text-slate-700">Activo</label>
      </div>
      <div class="flex items-center justify-between pt-4 border-t border-slate-100">
        <button type="button" onclick="document.getElementById('dlg-create').close()"
          class="text-sm font-medium text-slate-600 hover:text-slate-800 transition-colors">Cancelar</button>
        <button type="submit"
          class="bg-primary-600 hover:bg-primary-700 text-white text-sm font-semibold px-5 py-2.5 rounded-lg transition-colors">
          Crear administrador
        </button>
      </div>
    </form>
  </Dialog>

  <!-- Edit dialog -->
  <Dialog id="dlg-edit" title="Editar administrador" size="lg">
    <div id="edit-error" class="hidden mb-4 flex items-center gap-2 bg-red-50 border border-red-200 text-red-700 rounded-lg px-3 py-2.5 text-sm"></div>
    <form id="form-edit" class="space-y-4">
      <input type="hidden" id="edit-id" />
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1.5" for="e-nombre">
            Nombre completo <span class="text-red-500">*</span>
          </label>
          <input id="e-nombre" name="nombre_completo" type="text" required
            class="w-full px-3.5 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500" />
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1.5" for="e-documento">
            N° Documento <span class="text-red-500">*</span>
          </label>
          <input id="e-documento" name="numero_documento" type="text" required
            class="w-full px-3.5 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500" />
        </div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1.5" for="e-email">
            Email <span class="text-red-500">*</span>
          </label>
          <input id="e-email" name="email" type="email" required
            class="w-full px-3.5 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500" />
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1.5" for="e-celular">
            Celular <span class="text-slate-400 font-normal text-xs">(opcional)</span>
          </label>
          <input id="e-celular" name="celular" type="text"
            class="w-full px-3.5 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500" />
        </div>
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1.5" for="e-password">
          Nueva contraseña <span class="text-slate-400 font-normal text-xs">(dejar vacío para mantener)</span>
        </label>
        <input id="e-password" name="password" type="password" minlength="6"
          placeholder="••••••"
          class="w-full px-3.5 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500" />
      </div>
      <div class="flex items-center gap-3">
        <input id="e-active" name="is_active" type="checkbox"
          class="w-4 h-4 rounded border-slate-300 text-primary-600 focus:ring-primary-500" />
        <label for="e-active" class="text-sm font-medium text-slate-700">Activo</label>
      </div>
      <div class="flex items-center justify-between pt-4 border-t border-slate-100">
        <button type="button" onclick="document.getElementById('dlg-edit').close()"
          class="text-sm font-medium text-slate-600 hover:text-slate-800 transition-colors">Cancelar</button>
        <button type="submit"
          class="bg-primary-600 hover:bg-primary-700 text-white text-sm font-semibold px-5 py-2.5 rounded-lg transition-colors">
          Guardar cambios
        </button>
      </div>
    </form>
  </Dialog>

  <!-- Delete dialog -->
  <Dialog id="dlg-delete" title="Eliminar administrador" size="sm">
    <input type="hidden" id="delete-id" />
    <div class="flex items-start gap-4 mb-6">
      <div class="w-10 h-10 rounded-full bg-red-100 flex items-center justify-center shrink-0">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
        </svg>
      </div>
      <div>
        <p class="text-sm font-medium text-slate-800">¿Eliminar este administrador?</p>
        <p class="text-sm text-slate-500 mt-1">
          Se eliminará <strong id="delete-email" class="text-slate-700"></strong>. Esta acción no se puede deshacer.
        </p>
      </div>
    </div>
    <div class="flex items-center justify-end gap-3">
      <button type="button" onclick="document.getElementById('dlg-delete').close()"
        class="text-sm font-medium text-slate-600 hover:text-slate-800 transition-colors px-4 py-2">Cancelar</button>
      <button type="button" id="btn-delete-confirm"
        class="bg-red-600 hover:bg-red-700 text-white text-sm font-semibold px-5 py-2.5 rounded-lg transition-colors">
        Sí, eliminar
      </button>
    </div>
  </Dialog>

</AdminLayout>

<script is:inline>
  (function () {
    function esc(s) {
      if (s == null) return '';
      return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/"/g, '&quot;');
    }

    function setLoading(btn, isLoading, text) {
      if (!btn) return;
      if (isLoading) {
        if (!document.getElementById('_bspin')) {
          var s = document.createElement('style');
          s.id = '_bspin';
          s.textContent = '@keyframes _bspin{to{transform:rotate(360deg)}}';
          document.head.appendChild(s);
        }
        btn._origHTML = btn.innerHTML;
        btn.disabled = true;
        btn.style.opacity = '0.7';
        btn.style.cursor = 'not-allowed';
        btn.innerHTML =
          '<svg style="display:inline-block;width:1rem;height:1rem;margin-right:0.4rem;vertical-align:-0.175em;animation:_bspin 1s linear infinite" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle style="opacity:.25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path style="opacity:.75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>' +
          (text || 'Procesando…');
      } else {
        btn.disabled = false;
        btn.style.opacity = '';
        btn.style.cursor = '';
        if (btn._origHTML !== undefined) btn.innerHTML = btn._origHTML;
      }
    }

    function showFlash(msg, type) {
      var el = document.getElementById('adm-flash');
      if (!msg) { el.classList.add('hidden'); return; }
      el.classList.remove('hidden');
      el.className =
        'mb-5 flex items-center gap-3 rounded-xl px-4 py-3 text-sm border ' +
        (type === 'error'
          ? 'bg-red-50 border-red-200 text-red-700'
          : 'bg-green-50 border-green-200 text-green-700');
      el.textContent = msg;
    }

    function formatDate(iso) {
      if (!iso) return '—';
      var d = new Date(iso);
      return d.toLocaleDateString('es-PE', { day: '2-digit', month: 'short', year: 'numeric' });
    }

    function renderRows(list) {
      var tbody = document.getElementById('adm-tbody');
      var empty = document.getElementById('adm-empty');
      var wrap  = document.getElementById('adm-table-wrap');
      var count = document.getElementById('adm-count');

      count.textContent = list.length + ' administrador' + (list.length !== 1 ? 'es' : '') + ' en total';

      if (list.length === 0) {
        empty.classList.remove('hidden');
        wrap.classList.add('hidden');
        tbody.innerHTML = '';
        return;
      }
      empty.classList.add('hidden');
      wrap.classList.remove('hidden');

      tbody.innerHTML = list.map(function (u) {
        var active = !!u.is_active;
        var stCls  = active ? 'bg-green-100 text-green-700' : 'bg-slate-100 text-slate-500';
        var dot    = active ? 'bg-green-500' : 'bg-slate-400';
        var label  = active ? 'Activo' : 'Inactivo';
        return (
          '<tr class="hover:bg-slate-50/50 transition-colors">' +
          '<td class="px-6 py-4 font-medium text-slate-800 whitespace-nowrap">' + (esc(u.nombre_completo) || '<span class="text-slate-400">—</span>') + '</td>' +
          '<td class="px-6 py-4 text-slate-600">' + esc(u.email) + '</td>' +
          '<td class="px-6 py-4 text-slate-500 whitespace-nowrap">' + (esc(u.numero_documento) || '—') + '</td>' +
          '<td class="px-6 py-4 text-slate-500 whitespace-nowrap">' + (esc(u.celular) || '—') + '</td>' +
          '<td class="px-6 py-4">' +
          '<span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold ' + stCls + '">' +
          '<span class="w-1.5 h-1.5 rounded-full ' + dot + '"></span>' + label +
          '</span></td>' +
          '<td class="px-6 py-4 text-slate-500 text-xs whitespace-nowrap">' + formatDate(u.createdAt) + '</td>' +
          '<td class="px-6 py-4"><div class="flex items-center justify-end gap-2">' +
          '<button type="button" class="text-xs px-3 py-1.5 rounded-lg border border-primary-200 text-primary-600 hover:bg-primary-50 transition-colors" ' +
          'data-id="' + u.id + '" data-email="' + esc(u.email) + '" data-active="' + String(u.is_active) + '" ' +
          'data-nombre="' + esc(u.nombre_completo) + '" data-documento="' + esc(u.numero_documento) + '" data-celular="' + esc(u.celular) + '" ' +
          'onclick="openEditDialog(this)">Editar</button>' +
          (String(u.id) !== String(window.__barmarCurrentUserId)
            ? '<button type="button" class="text-xs px-3 py-1.5 rounded-lg border border-red-200 text-red-600 hover:bg-red-50 transition-colors" ' +
              'data-id="' + u.id + '" data-email="' + esc(u.email) + '" ' +
              'onclick="openDeleteDialog(this)">Eliminar</button>'
            : '<span class="text-xs px-3 py-1.5 text-slate-400 select-none" title="No puedes eliminar tu propio usuario">Tú</span>') +
          '</div></td></tr>'
        );
      }).join('');
    }

    window.loadAdmins = function () {
      return window.barmarAuthFetch('/api/admin/users')
        .then(function (r) { return r.json().then(function (j) { return { ok: r.ok, data: j.data || [] }; }); })
        .then(function (x) {
          if (!x.ok) throw new Error('fail');
          var admins = x.data.filter(function (u) { return u.role === 'admin'; });
          renderRows(admins);
          return admins;
        });
    };

    window.openEditDialog = function (btn) {
      var d = document.getElementById('dlg-edit');
      document.getElementById('edit-id').value        = btn.dataset.id;
      document.getElementById('e-nombre').value       = btn.dataset.nombre || '';
      document.getElementById('e-documento').value    = btn.dataset.documento || '';
      document.getElementById('e-email').value        = btn.dataset.email;
      document.getElementById('e-celular').value      = btn.dataset.celular || '';
      document.getElementById('e-password').value     = '';
      document.getElementById('e-active').checked     = btn.dataset.active === 'true';
      document.getElementById('edit-error').classList.add('hidden');
      d.showModal();
    };

    window.openDeleteDialog = function (btn) {
      document.getElementById('delete-id').value        = btn.dataset.id;
      document.getElementById('delete-email').textContent = btn.dataset.email;
      document.getElementById('dlg-delete').showModal();
    };

    function init() {
      /* ── Create ── */
      document.getElementById('form-create').addEventListener('submit', function (e) {
        e.preventDefault();
        var err = document.getElementById('create-error');
        err.classList.add('hidden');
        var btn = e.currentTarget.querySelector('[type="submit"]');
        var nombre    = document.getElementById('c-nombre').value;
        var documento = document.getElementById('c-documento').value;
        var email     = document.getElementById('c-email').value;
        var celular   = document.getElementById('c-celular').value;
        var password  = document.getElementById('c-password').value;
        var is_active = document.getElementById('c-active').checked;
        setLoading(btn, true, 'Creando…');
        window.barmarAuthFetch('/api/admin/users', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ nombre_completo: nombre, numero_documento: documento, email: email, celular: celular || null, password: password, role: 'admin', is_active: is_active }),
        })
          .then(function (r) { return r.json().then(function (d) { return { ok: r.ok, data: d }; }); })
          .then(function (x) {
            setLoading(btn, false);
            if (!x.ok) {
              var msgs = x.data.errors ? x.data.errors.map(function (e) { return e.message; }).join(' · ') : (x.data.message || 'No se pudo crear.');
              err.textContent = msgs;
              err.classList.remove('hidden');
              return;
            }
            document.getElementById('dlg-create').close();
            document.getElementById('form-create').reset();
            document.getElementById('c-active').checked = true;
            showFlash('Administrador creado correctamente.', 'success');
            return window.loadAdmins();
          })
          .catch(function () {
            setLoading(btn, false);
            err.textContent = 'Error de red.';
            err.classList.remove('hidden');
          });
      });

      /* ── Edit ── */
      document.getElementById('form-edit').addEventListener('submit', function (e) {
        e.preventDefault();
        var err = document.getElementById('edit-error');
        err.classList.add('hidden');
        var btn = e.currentTarget.querySelector('[type="submit"]');
        var id        = document.getElementById('edit-id').value;
        var nombre    = document.getElementById('e-nombre').value;
        var documento = document.getElementById('e-documento').value;
        var email     = document.getElementById('e-email').value;
        var celular   = document.getElementById('e-celular').value;
        var password  = document.getElementById('e-password').value;
        var is_active = document.getElementById('e-active').checked;
        var payload = { nombre_completo: nombre, numero_documento: documento, email: email, celular: celular || null, is_active: is_active };
        if (password.trim()) payload.password = password;
        setLoading(btn, true, 'Guardando…');
        window.barmarAuthFetch('/api/admin/users/' + id, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        })
          .then(function (r) { return r.json().then(function (d) { return { ok: r.ok, data: d }; }); })
          .then(function (x) {
            setLoading(btn, false);
            if (!x.ok) {
              var msgs = x.data.errors ? x.data.errors.map(function (e) { return e.message; }).join(' · ') : (x.data.message || 'No se pudo actualizar.');
              err.textContent = msgs;
              err.classList.remove('hidden');
              return;
            }
            document.getElementById('dlg-edit').close();
            showFlash('Administrador actualizado.', 'success');
            return window.loadAdmins();
          })
          .catch(function () {
            setLoading(btn, false);
            err.textContent = 'Error de red.';
            err.classList.remove('hidden');
          });
      });

      /* ── Delete ── */
      document.getElementById('btn-delete-confirm').addEventListener('click', function () {
        var btn = document.getElementById('btn-delete-confirm');
        var id  = document.getElementById('delete-id').value;
        setLoading(btn, true, 'Eliminando…');
        window.barmarAuthFetch('/api/admin/users/' + id, { method: 'DELETE' })
          .then(function (r) { return r.json().then(function (d) { return { ok: r.ok, data: d }; }); })
          .then(function (x) {
            setLoading(btn, false);
            document.getElementById('dlg-delete').close();
            if (!x.ok) { showFlash(x.data.message || 'No se pudo eliminar.', 'error'); return; }
            showFlash('Administrador eliminado correctamente.', 'success');
            return window.loadAdmins();
          })
          .catch(function () {
            setLoading(btn, false);
            showFlash('Error de red.', 'error');
          });
      });

      window.loadAdmins().catch(function () {
        document.getElementById('adm-count').textContent = 'No se pudieron cargar los administradores';
        showFlash('No se pudo conectar con el backend.', 'error');
      });
    }

    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
    else init();
  })();
</script>
