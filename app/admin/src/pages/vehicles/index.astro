  /* ── Vehicle assignment history dialog ─────────────────────────────────── */
  function vehFmtDate(iso) {
    if (!iso) return "—";
    var parts = String(iso).split("T")[0].split("-");
    var months = [
      "ene",
      "feb",
      "mar",
      "abr",
      "may",
      "jun",
      "jul",
      "ago",
      "sep",
      "oct",
      "nov",
      "dic",
    ];
    return parts[2] + " " + months[parseInt(parts[1], 10) - 1] + " " + parts[0];
  }

