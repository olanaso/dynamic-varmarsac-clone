    // Flags
    document
      .getElementById("vv-flag-approved")
      .classList.toggle("hidden", !v.is_approved);
    document
      .getElementById("vv-flag-pending")
      .classList.toggle("hidden", !!v.is_approved);
    document
      .getElementById("vv-flag-homologado")
      .classList.toggle("hidden", !v.homologado);

    // Maintenance progress bar
    var kmCurr = v.current_mileage || 0;
    var kmMaint = v.kilometraje_mantenimiento;
    var maintEl = document.getElementById("vv-maint");
    if (kmMaint != null) {
      maintEl.classList.remove("hidden");
      var diff = kmMaint - kmCurr;
      var pct = Math.min((kmCurr / kmMaint) * 100, 100);
      var priority = diff < 500 ? "alta" : diff < 1500 ? "media" : "baja";
      var exceeded = diff < 0;

      document.getElementById("vv-km-curr").textContent =
        kmCurr.toLocaleString() + " km";
      document.getElementById("vv-km-goal").textContent =
        kmMaint.toLocaleString() + " km";
      document.getElementById("vv-km-pct").textContent = Math.round(pct) + "%";

      var bar = document.getElementById("vv-km-bar");
      bar.style.width = pct + "%";
      var barColors = {
        alta: "bg-red-500",
        media: "bg-amber-400",
        baja: "bg-green-500",
      };
      bar.className =
        "h-full rounded-full transition-all " + barColors[priority];

      var prioEl = document.getElementById("vv-km-priority");
      var prioMap = {
        alta: [
          "Prioridad Alta",
          "text-red-700 bg-red-100 border border-red-200",
        ],
        media: [
          "Prioridad Media",
          "text-amber-700 bg-amber-100 border border-amber-200",
        ],
        baja: [
          "Prioridad Baja",
          "text-green-700 bg-green-100 border border-green-200",
        ],
      };
      var pInfo = prioMap[priority];
      prioEl.textContent = pInfo[0];
      prioEl.className =
        "text-xs font-semibold px-2.5 py-0.5 rounded-full " + pInfo[1];

      var kmStatusEl = document.getElementById("vv-km-status");
      if (exceeded) {
        kmStatusEl.textContent =
          "⚠ Superado por " + Math.abs(diff).toLocaleString() + " km";
        kmStatusEl.className = "text-xs text-red-600 font-medium";
      } else {
        kmStatusEl.textContent = "Faltan " + diff.toLocaleString() + " km";
        kmStatusEl.className = "text-xs text-slate-500";
      }
    } else {
      maintEl.classList.add("hidden");
    }

    document.getElementById("dlg-vehicle-view").showModal();
  };

