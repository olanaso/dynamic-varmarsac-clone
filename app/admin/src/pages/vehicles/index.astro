---
import AdminLayout from "../../layouts/AdminLayout.astro";
import Dialog from "../../components/Dialog.astro";
import VehicleSelectOptions from "../../components/VehicleSelectOptions.astro";
import {
  VEHICLE_STATUS_FILTER_OPTIONS,
  VEHICLE_APPROVAL_FILTER_OPTIONS,
  VEHICLE_TRANSMISSION_OPTIONS,
  VEHICLE_FUEL_OPTIONS,
  VEHICLE_TRACTION_OPTIONS,
  VEHICLE_STATUS_OPTIONS,
  VEHICLE_SELECT_PLACEHOLDER,
  getVehicleClientConfig,
} from "../../lib/vehicleConfig";

/** En sitio estático los datos se cargan en el navegador con `localStorage` + `barmarAuthFetch`. */
const PAGE_SIZE = 10;
const vehClientCfg = getVehicleClientConfig();
---

<AdminLayout title="Vehículos">
  <div
    class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6"
  >
    <form method="GET" id="veh-filter-form" class="flex flex-wrap gap-3">
      <input
        id="veh-inp-search"
        name="search"
        type="search"
        value=""
        placeholder="Buscar vehículo..."
        class="px-3.5 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500 w-52"
      />
      <select
        id="veh-sel-status"
        name="status"
        onchange="this.form.submit()"
        class="px-3.5 py-2 border border-slate-300 rounded-lg text-sm text-slate-700 focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white"
      >
        <VehicleSelectOptions options={VEHICLE_STATUS_FILTER_OPTIONS} />
      </select>
      <select
        id="veh-sel-approved"
        name="approved"
        onchange="this.form.submit()"
        class="px-3.5 py-2 border border-slate-300 rounded-lg text-sm text-slate-700 focus:outline-none focus:ring-2 focus:ring-primary-500 bg-white"
      >
        <VehicleSelectOptions options={VEHICLE_APPROVAL_FILTER_OPTIONS} />
      </select>
      <button
        type="submit"
        class="px-4 py-2 bg-slate-700 hover:bg-slate-800 text-white text-sm rounded-lg transition-colors"
        >Buscar</button
      >
      <a
        id="veh-link-clear"
        href="/vehicles"
        class="hidden px-4 py-2 text-sm text-slate-500 hover:text-slate-700 transition-colors flex items-center"
        >Limpiar</a
      >
    </form>
    <div class="flex items-center gap-2 shrink-0">
      <button
        type="button"
        id="btn-export-excel"
        class="inline-flex items-center gap-2 bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-semibold px-4 py-2.5 rounded-lg transition-colors"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-4 h-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
          ></path>
        </svg>
        Exportar Excel
      </button>
      <a
        href="/vehicles/new"
        class="inline-flex items-center gap-2 bg-primary-600 hover:bg-primary-700 text-white text-sm font-semibold px-4 py-2.5 rounded-lg transition-colors"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-4 h-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M12 4v16m8-8H4"></path>
        </svg>
        Nuevo vehículo
      </a>
    </div>
  </div>

  <div
    id="veh-flash"
    class="hidden mb-5 flex items-center gap-3 rounded-xl px-4 py-3 text-sm border"
  >
  </div>

  <p id="veh-loading" class="mb-4 text-sm text-slate-500">
    Cargando vehículos…
  </p>

  <div
    class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden"
  >
    <div
      id="veh-empty"
      class="hidden flex flex-col items-center justify-center py-16 text-slate-400"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="w-12 h-12 mb-3"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="1.5"
          d="M8 17H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v3m0 0h3l3 4v3h-3m-3 0H8m0 0a2 2 0 100 4 2 2 0 000-4zm9 0a2 2 0 100 4 2 2 0 000-4z"
        ></path>
      </svg>
      <p class="text-sm font-medium">No se encontraron vehículos</p>
      <p class="text-xs mt-1">Ajusta los filtros o agrega un nuevo vehículo.</p>
    </div>

    <div id="veh-table-wrap">
      <table class="w-full text-sm min-w-[900px]">
        <thead>
          <tr class="bg-slate-50 border-b border-slate-200">
            <th class="text-left px-4 py-3.5 font-semibold text-slate-600"
              >Vehículo</th
            >
            <th class="text-left px-4 py-3.5 font-semibold text-slate-600"
              >Categoría</th
            >
            <th class="text-left px-4 py-3.5 font-semibold text-slate-600"
              >Tipos de Servicio</th
            >
            <th class="text-left px-4 py-3.5 font-semibold text-slate-600"
              >Año</th
            >
            <th class="text-left px-4 py-3.5 font-semibold text-slate-600"
              >Tarifas</th
            >
            <th class="text-left px-4 py-3.5 font-semibold text-slate-600"
              >Estado</th
            >
            <th class="text-left px-4 py-3.5 font-semibold text-slate-600"
              >Flags</th
            >
            <th class="text-right px-4 py-3.5 font-semibold text-slate-600"
              >Acciones</th
            >
          </tr>
        </thead>
        <tbody id="vehicles-tbody" class="divide-y divide-slate-100"></tbody>
      </table>
    </div>

    <div
      id="veh-pager"
      class="hidden flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between px-4 md:px-6 py-4 border-t border-slate-100"
      data-page-size={PAGE_SIZE}
    >
      <p id="veh-pager-info" class="text-sm text-slate-500"></p>
      <div id="veh-pager-nav" class="flex flex-wrap gap-2">
        <button
          type="button"
          id="veh-pager-prev"
          class="px-3 py-1.5 text-sm border border-slate-300 rounded-lg text-slate-600 hover:bg-slate-50 transition-colors disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:bg-transparent"
        >
          ← Anterior
        </button>
        <button
          type="button"
          id="veh-pager-next"
          class="px-3 py-1.5 text-sm border border-slate-300 rounded-lg text-slate-600 hover:bg-slate-50 transition-colors disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:bg-transparent"
        >
          Siguiente →
        </button>
      </div>
    </div>
  </div>

  <!-- ═══ Vehicle edit dialog ════════════════════════════════════════════ -->
  <Dialog id="dlg-vehicle" title="Editar vehículo" size="lg">
    <form id="vd-form" class="space-y-3">
      <input type="hidden" name="id" id="vd-f-id" />

      <!-- Image preview + upload -->
      <div
        class="flex items-center gap-3 p-3 bg-slate-50 rounded-xl border border-slate-200"
      >
        <div
          class="w-16 h-16 rounded-lg overflow-hidden bg-slate-200 border border-slate-300 shrink-0 flex items-center justify-center"
        >
          <img
            id="vd-image"
            src=""
            alt="Vehículo"
            class="w-full h-full object-cover hidden"
          />
          <div id="vd-no-image" class="text-slate-400">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-7 h-7"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
              ></path>
            </svg>
          </div>
        </div>
        <div class="flex-1 min-w-0">
          <p id="vd-subtitle" class="text-xs text-slate-400 mb-1.5 truncate">
          </p>
          <label class="block text-xs font-medium text-slate-600 mb-1">
            Cambiar imagen <span class="font-normal text-slate-400"
              >(JPEG / PNG / WEBP · máx 5 MB)</span
            >
          </label>
          <input
            type="file"
            name="image"
            id="vd-f-image"
            accept="image/jpeg,image/png,image/webp"
            class="w-full text-xs text-slate-600 file:mr-2 file:py-1 file:px-3 file:rounded-md file:border-0 file:text-xs file:font-medium file:bg-primary-50 file:text-primary-700 hover:file:bg-primary-100 cursor-pointer"
          />
        </div>
      </div>

      <!-- Main fields 2-col grid -->
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label
            class="block text-xs font-medium text-slate-600 mb-1"
            for="vd-f-name">Nombre</label
          >
          <input
            id="vd-f-name"
            name="name"
            type="text"
            required
            class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500"
          />
        </div>
        <div>
          <label
            class="block text-xs font-medium text-slate-600 mb-1"
            for="vd-f-make">Marca</label
          >
          <input
            id="vd-f-make"
            name="make"
            type="text"
            required
            class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500"
          />
        </div>
        <div>
          <label
            class="block text-xs font-medium text-slate-600 mb-1"
            for="vd-f-regnum">Matrícula</label
          >
          <input
            id="vd-f-regnum"
            name="registration_number"
            type="text"
            required
            class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500"
          />
        </div>
        <div>
          <label
            class="block text-xs font-medium text-slate-600 mb-1"
            for="vd-f-year">Año</label
          >
          <input
            id="vd-f-year"
            name="year"
            type="number"
            min="1900"
            max="2100"
            required
            class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500"
          />
        </div>
        <div>
          <label
            class="block text-xs font-medium text-slate-600 mb-1"
            for="vd-f-catid">Categoría</label
          >
          <select
            id="vd-f-catid"
            name="category_id"
            required
            class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm text-slate-700 bg-white focus:outline-none focus:ring-2 focus:ring-primary-500"
          >
            <option value="">— Seleccionar —</option>
          </select>
        </div>
        <div>
          <label
            class="block text-xs font-medium text-slate-600 mb-1"
            for="vd-f-rate">Tarifa diaria (S/.)</label
          >
          <div class="relative">
            <span
              class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-xs font-medium select-none"
              >S/.</span
            >
            <input
              id="vd-f-rate"
              name="daily_rate"
              type="number"
              min="0"
              step="0.01"
              required
              class="w-full pl-9 pr-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500"
            />
          </div>
        </div>
        <div>
          <label
            class="block text-xs font-medium text-slate-600 mb-1"
            for="vd-f-monthly">Precio mensual (S/.)</label
          >
          <div class="relative">
            <span
              class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-xs font-medium select-none"
              >S/.</span
            >
            <input
              id="vd-f-monthly"
              name="precio_mensual"
              type="number"
              min="0"
              step="0.01"
              required
              class="w-full pl-9 pr-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500"
            />
          </div>
        </div>
        <div>
          <label
            class="block text-xs font-medium text-slate-600 mb-1"
            for="vd-f-passengers">Pasajeros</label
          >
          <input
            id="vd-f-passengers"
            name="cantidad_pasajeros"
            type="number"
            min="1"
            max="99"
            required
            class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500"
          />
        </div>
        <div>
          <label
            class="block text-xs font-medium text-slate-600 mb-1"
            for="vd-f-transmission">Transmisión</label
          >
          <select
            id="vd-f-transmission"
            name="tipo_transmision"
            required
            class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm text-slate-700 bg-white focus:outline-none focus:ring-2 focus:ring-primary-500"
          >
            <VehicleSelectOptions
              options={VEHICLE_TRANSMISSION_OPTIONS}
              placeholder={VEHICLE_SELECT_PLACEHOLDER}
            />
          </select>
        </div>
        <div>
          <label
            class="block text-xs font-medium text-slate-600 mb-1"
            for="vd-f-fuel">Combustible</label
          >
          <select
            id="vd-f-fuel"
            name="tipo_combustible"
            required
            class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm text-slate-700 bg-white focus:outline-none focus:ring-2 focus:ring-primary-500"
          >
            <VehicleSelectOptions
              options={VEHICLE_FUEL_OPTIONS}
              placeholder={VEHICLE_SELECT_PLACEHOLDER}
            />
          </select>
        </div>
        <div>
          <label
            class="block text-xs font-medium text-slate-600 mb-1"
            for="vd-f-traction">Tracción</label
          >
          <select
            id="vd-f-traction"
            name="tipo_traccion"
            required
            class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm text-slate-700 bg-white focus:outline-none focus:ring-2 focus:ring-primary-500"
          >
            <VehicleSelectOptions
              options={VEHICLE_TRACTION_OPTIONS}
              placeholder={VEHICLE_SELECT_PLACEHOLDER}
            />
          </select>
        </div>
        <div>
          <label
            class="block text-xs font-medium text-slate-600 mb-1"
            for="vd-f-status">Estado</label
          >
          <select
            id="vd-f-status"
            name="status"
            class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm text-slate-700 bg-white focus:outline-none focus:ring-2 focus:ring-primary-500"
          >
            <VehicleSelectOptions options={VEHICLE_STATUS_OPTIONS} />
          </select>
        </div>
        <div>
          <label
            class="block text-xs font-medium text-slate-600 mb-1"
            for="vd-f-km-current">KM actual</label
          >
          <input
            id="vd-f-km-current"
            name="current_mileage"
            type="number"
            min="0"
            required
            class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500"
          />
        </div>
        <div>
          <label
            class="block text-xs font-medium text-slate-600 mb-1"
            for="vd-f-km-maint"
          >
            KM mantenimiento <span class="font-normal text-slate-400"
              >(opcional)</span
            >
          </label>
          <input
            id="vd-f-km-maint"
            name="kilometraje_mantenimiento"
            type="number"
            min="1"
            placeholder="—"
            class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500"
          />
        </div>
        <div class="flex items-end gap-5 pb-1">
          <label class="flex items-center gap-2 cursor-pointer select-none">
            <input
              type="checkbox"
              id="vd-f-approved"
              class="w-4 h-4 rounded text-primary-600 border-slate-300 focus:ring-primary-500"
            />
            <span class="text-xs font-medium text-slate-700">Aprobado</span>
          </label>
          <label class="flex items-center gap-2 cursor-pointer select-none">
            <input
              type="checkbox"
              id="vd-f-homologado"
              class="w-4 h-4 rounded text-primary-600 border-slate-300 focus:ring-primary-500"
            />
            <span class="text-xs font-medium text-slate-700">Homologado</span>
          </label>
        </div>
      </div>

      <!-- Descripción -->
      <div>
        <label
          class="block text-xs font-medium text-slate-600 mb-1"
          for="vd-f-desc">Descripción</label
        >
        <textarea
          id="vd-f-desc"
          name="description"
          rows="2"
          class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm resize-none focus:outline-none focus:ring-2 focus:ring-primary-500"
          placeholder="Sin descripción"></textarea>
      </div>

      <!-- Equipamiento -->
      <div>
        <label
          class="block text-xs font-medium text-slate-600 mb-1"
          for="vd-equip-input">Equipamiento</label
        >
        <div class="flex gap-2">
          <input
            id="vd-equip-input"
            type="text"
            maxlength="80"
            placeholder="Ej. Aire acondicionado, Bluetooth…"
            class="flex-1 px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary-500"
          />
          <button
            type="button"
            id="vd-equip-add"
            class="shrink-0 px-3 py-2 text-xs font-semibold text-primary-700 bg-primary-50 border border-primary-200 rounded-lg hover:bg-primary-100 transition-colors"
          >
            Agregar
          </button>
        </div>
        <div id="vd-equip-tags" class="flex flex-wrap gap-2 mt-2 min-h-[1.5rem]"></div>
      </div>

      <!-- Tipos de servicio -->
      <div>
        <p class="text-xs font-medium text-slate-600 mb-1.5">
          Tipos de Servicio
        </p>
        <div id="vd-f-stypes" class="flex flex-wrap gap-2"></div>
      </div>

      <!-- Maintenance bar (read-only display) -->
      <div
        id="vd-maint-section"
        class="hidden bg-slate-50 border border-slate-200 rounded-xl p-3"
      >
        <div class="flex items-center justify-between mb-2">
          <span
            class="text-xs font-semibold text-slate-600 uppercase tracking-wide"
            >Estado de mantenimiento</span
          >
          <span
            id="vd-km-priority"
            class="text-xs font-semibold px-2 py-0.5 rounded-full"></span>
        </div>
        <div
          class="w-full h-2 bg-slate-200 rounded-full overflow-hidden mb-1.5"
        >
          <div
            id="vd-km-bar"
            class="h-full rounded-full transition-all bg-green-500"
            style="width:0%"
          >
          </div>
        </div>
        <div class="flex justify-between text-xs text-slate-400 mb-1">
          <span id="vd-km-curr"></span>
          <span id="vd-km-maint-label"></span>
        </div>
        <p id="vd-km-status-text" class="text-xs text-slate-500"></p>
      </div>

      <!-- Actions -->
      <div class="flex items-center gap-3 pt-1 border-t border-slate-100">
        <button
          type="submit"
          class="flex-1 bg-primary-600 hover:bg-primary-700 text-white text-sm font-semibold py-2.5 rounded-lg transition-colors"
        >
          Guardar cambios
        </button>
        <button
          type="button"
          onclick="document.getElementById('dlg-vehicle').close()"
          class="px-5 text-sm font-medium border border-slate-300 text-slate-600 hover:bg-slate-50 py-2.5 rounded-lg transition-colors"
        >
          Cancelar
        </button>
      </div>
    </form>
  </Dialog>

  <!-- ═══ Vehicle view dialog ════════════════════════════════════════════ -->
  <Dialog id="dlg-vehicle-view" title="Detalle del vehículo" size="lg">
    <div class="space-y-4">
      <!-- Image banner -->
      <div
        id="vv-img-wrap"
        class="hidden w-full rounded-xl overflow-hidden bg-slate-100 border border-slate-200"
        style="height:150px"
      >
        <img id="vv-image" src="" alt="" class="w-full h-full object-cover" />
      </div>

      <!-- Identity + status -->
      <div class="flex items-start justify-between gap-3">
        <div class="min-w-0">
          <h3 id="vv-name" class="text-base font-bold text-slate-800"></h3>
          <p id="vv-make-reg" class="text-xs text-slate-500 mt-0.5"></p>
        </div>
        <span
          id="vv-status"
          class="shrink-0 inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold"
        ></span>
      </div>

      <!-- Info grid -->
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-2.5">
        <div class="bg-slate-50 rounded-lg px-3 py-2.5 border border-slate-100">
          <p
            class="text-[10px] font-semibold text-slate-400 uppercase tracking-wide mb-0.5"
          >
            Categoría
          </p>
          <p id="vv-category" class="text-sm font-semibold text-slate-700"></p>
        </div>
        <div class="bg-slate-50 rounded-lg px-3 py-2.5 border border-slate-100">
          <p
            class="text-[10px] font-semibold text-slate-400 uppercase tracking-wide mb-0.5"
          >
            Año
          </p>
          <p id="vv-year" class="text-sm font-semibold text-slate-700"></p>
        </div>
        <div class="bg-slate-50 rounded-lg px-3 py-2.5 border border-slate-100">
          <p
            class="text-[10px] font-semibold text-slate-400 uppercase tracking-wide mb-0.5"
          >
            Tarifa diaria
          </p>
          <p id="vv-rate" class="text-sm font-semibold text-primary-700"></p>
        </div>
        <div class="bg-slate-50 rounded-lg px-3 py-2.5 border border-slate-100">
          <p
            class="text-[10px] font-semibold text-slate-400 uppercase tracking-wide mb-0.5"
          >
            Precio mensual
          </p>
