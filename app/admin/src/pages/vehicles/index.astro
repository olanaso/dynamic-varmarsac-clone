      .then(function (r) {
        return r.json();
      })
      .then(function (j) {
        var list = j.data || [];
        if (list.length === 0) {
          wrap.classList.add("hidden");
          empty.classList.remove("hidden");
          return;
        }
        wrap.classList.remove("hidden");
        empty.classList.add("hidden");
        tbody.innerHTML = list
          .map(function (a) {
            var cname = a.conductor ? vehEsc(a.conductor.nombre_completo) : "—";
            var cdoc = a.conductor ? vehEsc(a.conductor.numero_documento) : "—";
            var estadoCls =
              a.estado === "activa"
                ? "bg-green-100 text-green-700"
                : "bg-slate-100 text-slate-500";
            var acciones =
              a.estado === "activa"
                ? '<button type="button" class="text-xs px-2.5 py-1 rounded-lg border border-amber-200 text-amber-700 hover:bg-amber-50 transition-colors" onclick="vehCancelarAsig(' +
                  a.id +
