              '<tr class="hover:bg-slate-50/50">' +
              '<td class="px-4 py-3 font-medium text-slate-800 whitespace-nowrap">' +
              cname +
              "</td>" +
              '<td class="px-4 py-3 text-slate-500 whitespace-nowrap text-xs">' +
              cdoc +
              "</td>" +
              '<td class="px-4 py-3 text-slate-500 whitespace-nowrap text-xs">' +
              vehFmtDate(a.fecha_inicio) +
              "</td>" +
              '<td class="px-4 py-3 text-slate-500 whitespace-nowrap text-xs">' +
              vehFmtDate(a.fecha_limite) +
              "</td>" +
              '<td class="px-4 py-3"><span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold ' +
              estadoCls +
              '">' +
              (a.estado === "activa" ? "Activa" : "Cancelada") +
              "</span></td>" +
              '<td class="px-4 py-3 text-right whitespace-nowrap">' +
