    var tbody = document.getElementById("vehicles-tbody");
    var loading = document.getElementById("veh-loading");
    var empty = document.getElementById("veh-empty");
    var tableWrap = document.getElementById("veh-table-wrap");
    var pager = document.getElementById("veh-pager");
    var pageSize =
      typeof PAGE_SIZE === "number"
        ? PAGE_SIZE
        : parseInt(pager && pager.getAttribute("data-page-size"), 10) || 10;

    var allRows = [];
    var currentPage = 1;

    function renderTablePage() {
      if (!tbody) return;
      tbody.innerHTML = "";
      var total = allRows.length;
      var totalPages = Math.max(1, Math.ceil(total / pageSize));
      if (currentPage > totalPages) currentPage = totalPages;
      var start = (currentPage - 1) * pageSize;
      var end = Math.min(start + pageSize, total);
      for (var i = start; i < end; i++) {
        tbody.appendChild(allRows[i]);
      }

      var info = document.getElementById("veh-pager-info");
      var prev = document.getElementById("veh-pager-prev");
      var next = document.getElementById("veh-pager-next");
      var nav = document.getElementById("veh-pager-nav");
      if (info) {
        var lo = total ? start + 1 : 0;
        info.textContent =
          "Mostrando " +
          lo +
          "–" +
          end +
          " de " +
          total +
          " vehículos · Página " +
          currentPage +
          " de " +
          totalPages;
      }
      if (prev) prev.disabled = currentPage <= 1;
      if (next) next.disabled = currentPage >= totalPages;
      if (nav) nav.style.display = totalPages > 1 ? "" : "none";
    }

    function buildRow(v) {
      var tr = document.createElement("tr");
      tr.className = "vehicle-row hover:bg-slate-50/50 transition-colors";

      var imgCell = document.createElement("td");
      imgCell.className = "px-4 py-3.5";
      var flexImg = document.createElement("div");
      flexImg.className = "flex items-center gap-3";
      if (v.image) {
        var img = document.createElement("img");
        img.src = window.barmarUploadsUrl(v.image);
        img.alt = v.name;
        img.className =
          "w-10 h-10 rounded-lg object-cover bg-slate-100 shrink-0";
        flexImg.appendChild(img);
      } else {
        flexImg.innerHTML =
          '<div class="w-10 h-10 rounded-lg bg-slate-100 flex items-center justify-center shrink-0">' +
          '<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">' +
          '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 17H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v3m0 0h3l3 4v3h-3m-3 0H8m0 0a2 2 0 100 4 2 2 0 000-4zm9 0a2 2 0 100 4 2 2 0 000-4z"/></svg></div>';
      }
      var textWrap = document.createElement("div");
      var pName = document.createElement("p");
      pName.className = "font-medium text-slate-800";
      pName.textContent = v.name;
      var pSub = document.createElement("p");
      pSub.className = "text-xs text-slate-400";
      pSub.textContent = v.make + " · " + v.registration_number;
      textWrap.appendChild(pName);
      textWrap.appendChild(pSub);
      flexImg.appendChild(textWrap);
      imgCell.appendChild(flexImg);

      var catCell = document.createElement("td");
      catCell.className = "px-4 py-3.5 text-slate-600 text-xs";
      catCell.textContent =
        v.category && v.category.name ? v.category.name : "—";

      var stCell = document.createElement("td");
      stCell.className = "px-4 py-3.5";
      var stWrap = document.createElement("div");
      stWrap.className = "flex flex-wrap gap-1 max-w-[160px]";
      var types = v.serviceTypes || [];
      if (types.length === 0) {
        stWrap.innerHTML = '<span class="text-xs text-slate-400">—</span>';
      } else {
        types.slice(0, 2).forEach(function (st) {
          var sp = document.createElement("span");
          sp.className =
            "inline-block px-2 py-0.5 rounded-full bg-primary-100 text-primary-700 text-xs font-medium";
          sp.textContent = st.name;
          stWrap.appendChild(sp);
        });
        if (types.length > 2) {
          var more = document.createElement("span");
          more.className =
            "inline-block px-2 py-0.5 rounded-full bg-slate-100 text-slate-500 text-xs";
          more.textContent = "+" + (types.length - 2);
          stWrap.appendChild(more);
        }
      }
      stCell.appendChild(stWrap);

      var yearCell = document.createElement("td");
      yearCell.className = "px-4 py-3.5 text-slate-600";
      yearCell.textContent = String(v.year);

      var rateCell = document.createElement("td");
      rateCell.className = "px-4 py-3.5 text-slate-800";
      rateCell.innerHTML =
        '<div class="font-medium">S/. ' +
        Number(v.daily_rate).toFixed(2) +
        '<span class="text-slate-400 font-normal text-xs">/día</span></div>' +
        '<div class="text-xs text-slate-500 mt-0.5">S/. ' +
        Number(v.precio_mensual || 0).toFixed(2) +
        "/mes</div>";

      var statCell = document.createElement("td");
      statCell.className = "px-4 py-3.5";
      var badge = document.createElement("span");
      var sc = statusColors[v.status] || "bg-slate-100 text-slate-600";
      badge.className =
        "inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold " +
        sc;
      badge.textContent = statusLabels[v.status] || v.status;
      statCell.appendChild(badge);

      var flagsCell = document.createElement("td");
      flagsCell.className = "px-4 py-3.5";
      var flagsInner = document.createElement("div");
      flagsInner.className = "flex flex-col gap-1";
      if (v.is_approved) {
        flagsInner.innerHTML +=
          '<span class="inline-flex items-center gap-1 text-xs text-green-700 font-medium">' +
          '<svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">' +
          '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>Aprobado</span>';
      } else {
        flagsInner.innerHTML +=
          '<span class="inline-flex items-center gap-1 text-xs text-amber-600 font-medium">' +
          '<svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">' +
          '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>Pendiente</span>';
      }
      if (v.homologado) {
        flagsInner.innerHTML +=
          '<span class="inline-flex items-center gap-1 text-xs text-primary-600 font-medium">' +
          '<svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">' +
          '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>Homologado</span>';
      }
      flagsCell.appendChild(flagsInner);

      var payload = Object.assign({}, v, {
        imageUrl: v.image ? window.barmarUploadsUrl(v.image) : null,
      });
      var dataVeh = encodeURIComponent(JSON.stringify(payload));

      var actionsCell = document.createElement("td");
      actionsCell.className = "px-4 py-3.5";
      var actionsWrap = document.createElement("div");
      actionsWrap.className = "flex items-center justify-end gap-1";

      actionsWrap.innerHTML =
        '<span class="relative inline-flex group">' +
        '<button type="button" data-vehicle="' +
        dataVeh +
        '" onclick="openVehicleViewDialog(this)" class="inline-flex items-center justify-center rounded-lg border border-slate-200 p-2 text-slate-600 hover:bg-slate-50 transition-colors focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-1" aria-label="Ver detalle">' +
        '<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">' +
        '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />' +
        '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg></button>' +
        '<span class="pointer-events-none absolute left-1/2 top-full z-20 mt-1.5 -translate-x-1/2 whitespace-nowrap rounded-md bg-slate-800 px-2 py-1 text-[11px] font-medium text-white shadow-md opacity-0 transition-opacity duration-150 group-hover:opacity-100 group-focus-within:opacity-100">Ver detalle</span></span>';

      if (!v.is_approved) {
        var appr = document.createElement("span");
        appr.className = "relative inline-flex group";
        appr.innerHTML =
          '<button type="button" class="veh-btn-approve inline-flex items-center justify-center rounded-lg border border-green-200 p-2 text-green-700 hover:bg-green-50 transition-colors focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-1" data-id="' +
          vehEsc(String(v.id)) +
          '" aria-label="Aprobar vehículo">' +
          '<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">' +
          '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg></button>' +
          '<span class="pointer-events-none absolute left-1/2 top-full z-20 mt-1.5 -translate-x-1/2 whitespace-nowrap rounded-md bg-slate-800 px-2 py-1 text-[11px] font-medium text-white shadow-md opacity-0 transition-opacity duration-150 group-hover:opacity-100 group-focus-within:opacity-100">Aprobar</span>';
        actionsWrap.appendChild(appr);
      }

      var editSpan = document.createElement("span");
      editSpan.className = "relative inline-flex group";
      editSpan.innerHTML =
        '<button type="button" data-vehicle="' +
        dataVeh +
        '" onclick="openVehicleDialog(this)" class="inline-flex items-center justify-center rounded-lg border border-primary-200 p-2 text-primary-600 hover:bg-primary-50 transition-colors focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-1" aria-label="Editar vehículo en modal">' +
        '<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">' +
        '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg></button>' +
        '<span class="pointer-events-none absolute left-1/2 top-full z-20 mt-1.5 -translate-x-1/2 whitespace-nowrap rounded-md bg-slate-800 px-2 py-1 text-[11px] font-medium text-white shadow-md opacity-0 transition-opacity duration-150 group-hover:opacity-100 group-focus-within:opacity-100">Editar (modal)</span>';
      actionsWrap.appendChild(editSpan);

      var histSpan = document.createElement("span");
      histSpan.className = "relative inline-flex group";
      histSpan.innerHTML =
        '<button type="button" data-id="' +
        vehEsc(String(v.id)) +
        '" data-name="' +
        vehEsc(v.name) +
        '" ' +
        'onclick="openVehHistorialDialog(this)" class="inline-flex items-center justify-center rounded-lg border border-slate-200 p-2 text-slate-500 hover:bg-slate-50 transition-colors focus:outline-none focus:ring-2 focus:ring-slate-400 focus:ring-offset-1" aria-label="Historial de asignaciones">' +
        '<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">' +
        '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg></button>' +
        '<span class="pointer-events-none absolute left-1/2 top-full z-20 mt-1.5 -translate-x-1/2 whitespace-nowrap rounded-md bg-slate-800 px-2 py-1 text-[11px] font-medium text-white shadow-md opacity-0 transition-opacity duration-150 group-hover:opacity-100 group-focus-within:opacity-100">Historial asignaciones</span>';
      actionsWrap.appendChild(histSpan);

      var asignSpan = document.createElement("span");
      asignSpan.className = "relative inline-flex group";
      asignSpan.innerHTML =
        '<button type="button" data-id="' +
        vehEsc(String(v.id)) +
        '" data-name="' +
        vehEsc(v.name) +
        '" ' +
        'onclick="openAsignarConductorDialog(this)" class="inline-flex items-center justify-center rounded-lg border border-violet-200 p-2 text-violet-600 hover:bg-violet-50 transition-colors focus:outline-none focus:ring-2 focus:ring-violet-500 focus:ring-offset-1" aria-label="Asignar conductor">' +
        '<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">' +
        '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg></button>' +
        '<span class="pointer-events-none absolute left-1/2 top-full z-20 mt-1.5 -translate-x-1/2 whitespace-nowrap rounded-md bg-slate-800 px-2 py-1 text-[11px] font-medium text-white shadow-md opacity-0 transition-opacity duration-150 group-hover:opacity-100 group-focus-within:opacity-100">Asignar conductor</span>';
      actionsWrap.appendChild(asignSpan);

      var delSpan = document.createElement("span");
      delSpan.className = "relative inline-flex group";
      delSpan.innerHTML =
        '<button type="button" data-id="' +
        vehEsc(String(v.id)) +
        '" data-name="' +
        vehEsc(v.name) +
        '" onclick="openDeleteDialog(this)" class="inline-flex items-center justify-center rounded-lg border border-red-200 p-2 text-red-600 hover:bg-red-50 transition-colors focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-1" aria-label="Eliminar vehículo">' +
        '<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">' +
        '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg></button>' +
        '<span class="pointer-events-none absolute left-1/2 top-full z-20 mt-1.5 -translate-x-1/2 whitespace-nowrap rounded-md bg-slate-800 px-2 py-1 text-[11px] font-medium text-white shadow-md opacity-0 transition-opacity duration-150 group-hover:opacity-100 group-focus-within:opacity-100">Eliminar</span>';
      actionsWrap.appendChild(delSpan);

      actionsCell.appendChild(actionsWrap);

      tr.appendChild(imgCell);
      tr.appendChild(catCell);
      tr.appendChild(stCell);
      tr.appendChild(yearCell);
      tr.appendChild(rateCell);
      tr.appendChild(statCell);
      tr.appendChild(flagsCell);
      tr.appendChild(actionsCell);
      return tr;
    }

    async function loadVehicles() {
      vehHideFlash();
      if (loading) {
        loading.classList.remove("hidden");
        loading.textContent = "Cargando vehículos…";
      }
      if (empty) empty.classList.add("hidden");
      if (tableWrap) tableWrap.classList.add("hidden");
      if (pager) pager.classList.add("hidden");
      if (tbody) tbody.innerHTML = "";

      try {
        var list = await vehFetchAllFiltered();
        _allVehiclesData = list;
        allRows = list.map(buildRow);
        currentPage = 1;
        if (loading) loading.classList.add("hidden");
        if (list.length === 0) {
          if (empty) empty.classList.remove("hidden");
        } else {
          if (tableWrap) tableWrap.classList.remove("hidden");
          if (pager) pager.classList.remove("hidden");
          renderTablePage();
        }
      } catch (e) {
        if (loading) loading.classList.add("hidden");
        vehShowFlash(e.message || "Error al cargar vehículos", "error");
      }
    }

    window.__vehiclesReload = loadVehicles;

    function run() {
      vehSyncFiltersFromUrl();

      window._vdEquipGetTags = initEquipamientoTags({
        inputId: "vd-equip-input",
        addBtnId: "vd-equip-add",
        containerId: "vd-equip-tags",
        initial: [],
      });

      document
        .getElementById("veh-pager-prev")
        .addEventListener("click", function () {
          if (currentPage > 1) {
            currentPage--;
            renderTablePage();
          }
        });
      document
        .getElementById("veh-pager-next")
        .addEventListener("click", function () {
          var totalPages = Math.max(1, Math.ceil(allRows.length / pageSize));
          if (currentPage < totalPages) {
            currentPage++;
            renderTablePage();
          }
        });

      var vdForm = document.getElementById("vd-form");
      if (vdForm) {
        vdForm.addEventListener("submit", async function (ev) {
          ev.preventDefault();
          var btn = vdForm.querySelector('[type="submit"]');
          var id = document.getElementById("vd-f-id").value;
          var fd = new FormData(vdForm);
          fd.delete("id");
          fd.set(
            "is_approved",
            document.getElementById("vd-f-approved").checked ? "true" : "false",
          );
          fd.set(
            "homologado",
            document.getElementById("vd-f-homologado").checked
              ? "true"
              : "false",
          );
          var kmMaint = fd.get("kilometraje_mantenimiento");
          if (!kmMaint || String(kmMaint).trim() === "") {
            fd.delete("kilometraje_mantenimiento");
          }
          appendEquipamientoToFormData(fd, window._vdEquipGetTags);
          vehSetLoading(btn, true);
          try {
            var res = await window.barmarAuthFetch(
              "/api/admin/vehicles/" + encodeURIComponent(id),
              {
                method: "PUT",
                body: fd,
              },
            );
            if (res.status === 401) {
              window.location.href = "/login";
              return;
            }
            var data = await res.json().catch(function () {
              return {};
            });
            if (!res.ok) {
              vehShowFlash(data.message || "No se pudo guardar", "error");
              return;
            }
            document.getElementById("dlg-vehicle").close();
            vehShowFlash("Cambios guardados.", "success");
            await loadVehicles();
          } catch (err) {
            vehShowFlash(err.message || "Error de red", "error");
          } finally {
            vehSetLoading(btn, false);
          }
        });
      }

      var delBtn = document.getElementById("delete-vehicle-confirm");
      if (delBtn) {
        delBtn.addEventListener("click", async function () {
          var id = document.getElementById("delete-vehicle-id").value;
          if (!id) return;
          try {
            var res = await window.barmarAuthFetch(
              "/api/admin/vehicles/" + encodeURIComponent(id),
              {
                method: "DELETE",
              },
            );
            if (res.status === 401) {
              window.location.href = "/login";
              return;
            }
            var data = await res.json().catch(function () {
              return {};
            });
            if (!res.ok) {
              vehShowFlash(data.message || "No se pudo eliminar", "error");
              return;
            }
            document.getElementById("dlg-delete").close();
            vehShowFlash("Vehículo eliminado.", "success");
            await loadVehicles();
          } catch (err) {
            vehShowFlash(err.message || "Error de red", "error");
          }
        });
      }

      if (tbody) {
        tbody.addEventListener("click", async function (e) {
          var btn = e.target.closest(".veh-btn-approve");
          if (!btn) return;
          var vid = btn.getAttribute("data-id");
          if (!vid) return;
          try {
            var res = await window.barmarAuthFetch(
              "/api/admin/vehicles/" + encodeURIComponent(vid) + "/approve",
              {
                method: "PATCH",
              },
            );
            if (res.status === 401) {
              window.location.href = "/login";
              return;
            }
            var data = await res.json().catch(function () {
              return {};
            });
            if (!res.ok) {
              vehShowFlash(data.message || "No se pudo aprobar", "error");
              return;
            }
            vehShowFlash("Vehículo aprobado.", "success");
            await loadVehicles();
          } catch (err) {
            vehShowFlash(err.message || "Error de red", "error");
          }
        });
      }

      var asignarCondForm = document.getElementById("form-asignar-conductor");
      if (asignarCondForm) {
        asignarCondForm.addEventListener("submit", async function (e) {
          e.preventDefault();
          var err = document.getElementById("veh-asignar-error");
          err.classList.add("hidden");
          var btn = asignarCondForm.querySelector('[type="submit"]');
          var vehicleId = document.getElementById(
            "veh-asignar-vehicle-id",
          ).value;
          var conductorId = _asignarCondSelect
            ? _asignarCondSelect.getValue()
            : "";
          var inicio = document.getElementById("veh-asignar-inicio").value;
          var limite = document.getElementById("veh-asignar-limite").value;
          if (!conductorId) {
            err.textContent = "Selecciona un conductor.";
            err.classList.remove("hidden");
            return;
          }
          vehSetLoading(btn, true);
          try {
            var res = await window.barmarAuthFetch("/api/admin/asignaciones", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({
                conductor_id: Number(conductorId),
                vehicle_id: Number(vehicleId),
                fecha_inicio: inicio,
                fecha_limite: limite,
              }),
            });
            var data = await res.json();
            if (!res.ok) {
              err.textContent =
                (data.errors &&
                  data.errors
                    .map(function (e) {
                      return e.message;
                    })
                    .join(" · ")) ||
                data.message ||
                "No se pudo asignar.";
              err.classList.remove("hidden");
              return;
            }
            document.getElementById("dlg-asignar-conductor").close();
            vehShowFlash("Conductor asignado correctamente.", "success");
          } catch (ex) {
            err.textContent = "Error de red.";
            err.classList.remove("hidden");
          } finally {
            vehSetLoading(btn, false);
          }
        });
      }

      var exportBtn = document.getElementById("btn-export-excel");
      if (exportBtn) exportBtn.addEventListener("click", exportFlotaExcel);

      loadVehicles();
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", run);
    } else {
      run();
    }
  })();
</script>
