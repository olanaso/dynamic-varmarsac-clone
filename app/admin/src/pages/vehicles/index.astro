<script is:inline define:vars={{ PAGE_SIZE, vehClientCfg }}>
  function vehShowFlash(message, type) {
    var el = document.getElementById("veh-flash");
    if (!el || !message) return;
    var ok = type === "success";
    el.className =
      "mb-5 flex items-center gap-3 rounded-xl px-4 py-3 text-sm border " +
      (ok
        ? "bg-green-50 border-green-200 text-green-700"
        : "bg-red-50 border-red-200 text-red-700");
    el.textContent = message;
    el.classList.remove("hidden");
  }

  function vehHideFlash() {
    var el = document.getElementById("veh-flash");
    if (el) {
      el.classList.add("hidden");
      el.textContent = "";
    }
  }

  function vehSetLoading(btn, isLoading) {
    if (!btn) return;
    if (isLoading) {
      if (!document.getElementById("_bspin")) {
        var s = document.createElement("style");
        s.id = "_bspin";
        s.textContent = "@keyframes _bspin{to{transform:rotate(360deg)}}";
        document.head.appendChild(s);
      }
      btn._origHTML = btn.innerHTML;
      btn.disabled = true;
      btn.style.opacity = "0.7";
      btn.style.cursor = "not-allowed";
      btn.innerHTML =
        '<svg style="display:inline-block;width:1rem;height:1rem;margin-right:0.4rem;vertical-align:-0.175em;animation:_bspin 1s linear infinite" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle style="opacity:.25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path style="opacity:.75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>Guardando…';
    } else {
      btn.disabled = false;
      btn.style.opacity = "";
      btn.style.cursor = "";
      if (btn._origHTML !== undefined) btn.innerHTML = btn._origHTML;
    }
  }

  function vehSyncFiltersFromUrl() {
    var u = new URL(window.location.href);
    var s = document.getElementById("veh-inp-search");
    var st = document.getElementById("veh-sel-status");
    var ap = document.getElementById("veh-sel-approved");
    var clr = document.getElementById("veh-link-clear");
    if (s) s.value = u.searchParams.get("search") || "";
    if (st) st.value = u.searchParams.get("status") || "";
    if (ap) ap.value = u.searchParams.get("approved") || "";
    if (clr) {
      var has = !!(
        u.searchParams.get("search") ||
        u.searchParams.get("status") ||
        u.searchParams.get("approved")
      );
      clr.classList.toggle("hidden", !has);
    }
  }

  function vehListQueryParams() {
    var u = new URL(window.location.href);
    var q = new URLSearchParams();
    var search = u.searchParams.get("search");
    var status = u.searchParams.get("status");
    var approved = u.searchParams.get("approved");
    if (search) q.set("search", search);
    if (status) q.set("status", status);
    if (approved === "true" || approved === "false")
      q.set("is_approved", approved);
    return q;
  }

  async function vehFetchAllFiltered() {
    var baseQ = vehListQueryParams();
    var all = [];
    var page = 1;
    var limit = 100;
    for (;;) {
      var q = new URLSearchParams(baseQ);
      q.set("page", String(page));
      q.set("limit", String(limit));
      var res = await window.barmarAuthFetch(
        "/api/admin/vehicles?" + q.toString(),
      );
      if (res.status === 401) {
        window.location.href = "/login";
        return [];
      }
      if (!res.ok) {
        var errText = await res.text();
        throw new Error(errText || res.statusText);
      }
      var json = await res.json();
      var data = json.data || [];
      all = all.concat(data);
      var totalPages =
        json.pagination && json.pagination.totalPages
          ? json.pagination.totalPages
          : 1;
      if (page >= totalPages || data.length === 0) break;
      page++;
    }
    return all;
  }

  function vehEsc(s) {
    if (s == null) return "";
    return String(s)
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;");
  }

  function initEquipamientoTags(opts) {
    var tags = Array.isArray(opts.initial) ? opts.initial.slice() : [];
    var input = document.getElementById(opts.inputId);
    var addBtn = document.getElementById(opts.addBtnId);
    var container = document.getElementById(opts.containerId);
    if (!input || !addBtn || !container) return function () { return []; };

    function render() {
      container.innerHTML = "";
      if (!tags.length) {
        container.innerHTML =
          '<span class="text-xs text-slate-400">Sin etiquetas</span>';
        return;
      }
      tags.forEach(function (tag, idx) {
        var pill = document.createElement("span");
        pill.className =
          "inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-emerald-50 border border-emerald-200 text-xs font-medium text-emerald-800";
        var txt = document.createElement("span");
        txt.textContent = tag;
        var rm = document.createElement("button");
        rm.type = "button";
        rm.className = "text-emerald-600/70 hover:text-red-600 leading-none px-0.5";
        rm.innerHTML = "&times;";
        rm.addEventListener("click", function () {
          tags.splice(idx, 1);
          render();
        });
        pill.appendChild(txt);
        pill.appendChild(rm);
        container.appendChild(pill);
      });
    }

    function addTag() {
      var val = (input.value || "").trim();
      if (!val) return;
      if (tags.indexOf(val) !== -1) {
        input.value = "";
        return;
      }
      if (tags.length >= vehClientCfg.maxEquipamientoTags) return;
      tags.push(val);
      input.value = "";
      render();
    }

    if (addBtn._equipClick) addBtn.removeEventListener("click", addBtn._equipClick);
    addBtn._equipClick = addTag;
    addBtn.addEventListener("click", addTag);

    if (input._equipKey) input.removeEventListener("keydown", input._equipKey);
    input._equipKey = function (e) {
      if (e.key === "Enter") {
        e.preventDefault();
        addTag();
      }
    };
    input.addEventListener("keydown", input._equipKey);

    render();
    return function () {
      return tags.slice();
    };
  }

  function appendEquipamientoToFormData(fd, getTags) {
    fd.delete("equipamiento");
    var tags = getTags ? getTags() : [];
    if (!tags.length) {
      fd.append("equipamiento", "[]");
      return;
    }
    tags.forEach(function (tag) {
      fd.append("equipamiento", tag);
    });
  }

  var statusColors = vehClientCfg.statusColors;
  var statusLabels = vehClientCfg.statusLabels;
  var vehTransLabels = vehClientCfg.transmissionLabels;
  var vehFuelLabels = vehClientCfg.fuelLabels;
  var vehTractionLabels = vehClientCfg.tractionLabels;

  function vehSpecLabel(map, key) {
    return key && map[key] ? map[key] : key || "—";
  }

  function normalizeEquipamiento(val) {
    if (Array.isArray(val)) {
      return val.map(function (item) { return String(item).trim(); }).filter(Boolean);
    }
    if (typeof val === "string") {
      var trimmed = val.trim();
      if (!trimmed) return [];
      try {
        var parsed = JSON.parse(trimmed);
        return Array.isArray(parsed)
          ? parsed.map(function (item) { return String(item).trim(); }).filter(Boolean)
          : [];
      } catch (e) {
        return trimmed.split(",").map(function (s) { return s.trim(); }).filter(Boolean);
      }
    }
    return [];
  }

  window.__vehiclesReload = null;
  var _allVehiclesData = [];

  /* ── Excel export (ExcelJS — preserva estilos de la plantilla) ─────────── */
  var _excelJsLoaded = false;

  function loadExcelJs() {
    if (_excelJsLoaded || window.ExcelJS) {
      _excelJsLoaded = true;
      return Promise.resolve();
    }
    return new Promise(function (resolve, reject) {
      var s = document.createElement("script");
      s.src = "https://cdn.jsdelivr.net/npm/exceljs@4.4.0/dist/exceljs.min.js";
      s.onload = function () {
        _excelJsLoaded = true;
        resolve();
      };
      s.onerror = reject;
      document.head.appendChild(s);
    });
  }

  var _exportStatusLabels = vehClientCfg.exportStatusLabels;

  async function exportFlotaExcel() {
    var btn = document.getElementById("btn-export-excel");
    if (btn) {
      btn._orig = btn.innerHTML;
      btn.disabled = true;
      btn.style.opacity = "0.7";
      btn.textContent = "Generando…";
    }
    try {
      await loadExcelJs();

      // Fetch template bytes (served from public/)
      var resp = await fetch("/plantilla-flota.xlsx");
      if (!resp.ok) throw new Error("No se encontró /plantilla-flota.xlsx");
      var ab = await resp.arrayBuffer();

      // Load template — ExcelJS preserva estilos, bordes, merges, etc.
      var wb = new window.ExcelJS.Workbook();
      await wb.xlsx.load(ab);
      var ws = wb.worksheets[0];

      var data = _allVehiclesData;

      // Fila 4: encabezados (A=Matrícula … L=Estado)
      var hdr = ws.getRow(4);
      hdr.getCell(1).value = "Matrícula";
      hdr.getCell(2).value = "Nombre";
      hdr.getCell(3).value = "Categoría";
      hdr.getCell(4).value = "Pasajeros";
      hdr.getCell(5).value = "Transmisión";
      hdr.getCell(6).value = "Combustible";
      hdr.getCell(7).value = "Año";
      hdr.getCell(8).value = "Tarifa diaria";
      hdr.getCell(9).value = "Homologado";
      hdr.getCell(10).value = "KM actual";
      hdr.getCell(11).value = "KM mantenimiento";
      hdr.getCell(12).value = "Estado";
      hdr.commit();

      data.forEach(function (v, i) {
        var row = ws.getRow(5 + i);
        row.getCell(1).value = v.registration_number || "";
        row.getCell(2).value = v.name || "";
        row.getCell(3).value =
          v.category && v.category.name ? v.category.name : "";
        row.getCell(4).value =
          v.cantidad_pasajeros != null ? Number(v.cantidad_pasajeros) : "";
        row.getCell(5).value = vehSpecLabel(vehTransLabels, v.tipo_transmision);
        row.getCell(6).value = vehSpecLabel(vehFuelLabels, v.tipo_combustible);
        row.getCell(7).value = Number(v.year);
        row.getCell(8).value = parseFloat(v.daily_rate);
        row.getCell(9).value = v.homologado ? "Si" : "No";
        row.getCell(10).value = Number(v.current_mileage || 0);
        row.getCell(11).value =
          v.kilometraje_mantenimiento != null
            ? Number(v.kilometraje_mantenimiento)
            : "";
        row.getCell(12).value = _exportStatusLabels[v.status] || v.status;
        row.commit();
      });

      // Write to buffer and trigger download
      var buffer = await wb.xlsx.writeBuffer();
      var blob = new Blob([buffer], {
        type: "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
      });
      var url = URL.createObjectURL(blob);
      var a = document.createElement("a");
      a.href = url;
      var _statusFileLabels = vehClientCfg.exportStatusFileLabels;
      var _selStatus =
        (document.getElementById("veh-sel-status") || {}).value || "";
      var _filePart = _selStatus
        ? (_statusFileLabels[_selStatus] || _selStatus.toLowerCase()) + "-"
        : "";
      a.download =
        "flota-" + _filePart + new Date().toISOString().split("T")[0] + ".xlsx";
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
    } catch (err) {
      vehShowFlash("Error al exportar: " + (err.message || err), "error");
    } finally {
      if (btn) {
        btn.disabled = false;
        btn.style.opacity = "";
        btn.innerHTML = btn._orig;
      }
    }
  }

