  window.vehCancelarAsig = function (id, btn) {
    if (btn.disabled) return;
    btn.disabled = true;
    btn.textContent = "…";
    window
      .barmarAuthFetch("/api/admin/asignaciones/" + id + "/cancelar", {
        method: "PATCH",
      })
      .then(function (r) {
        return r.json().then(function (d) {
          return { ok: r.ok, data: d };
        });
      })
      .then(function (x) {
        if (!x.ok) {
          vehShowFlash(x.data.message || "Error.", "error");
          btn.disabled = false;
          btn.textContent = "Cancelar";
          return;
        }
        vehShowFlash("Asignación cancelada.", "success");
        var row = btn.closest("tr");
        if (row) {
          var cells = row.querySelectorAll("td");
          if (cells[4])
            cells[4].innerHTML =
              '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-slate-100 text-slate-500">Cancelada</span>';
          if (cells[5])
            cells[5].innerHTML =
              '<button type="button" class="text-xs px-2.5 py-1 rounded-lg border border-red-200 text-red-600 hover:bg-red-50 transition-colors" onclick="vehEliminarAsig(' +
              id +
              ', this)">Eliminar</button>';
        }
      })
      .catch(function () {
        btn.disabled = false;
        btn.textContent = "Cancelar";
        vehShowFlash("Error de red.", "error");
      });
  };

  window.vehEliminarAsig = function (id, btn) {
    if (!confirm("¿Eliminar esta asignación permanentemente?")) return;
    btn.disabled = true;
    btn.textContent = "…";
    window
      .barmarAuthFetch("/api/admin/asignaciones/" + id, { method: "DELETE" })
      .then(function (r) {
        return r.json().then(function (d) {
          return { ok: r.ok, data: d };
        });
      })
      .then(function (x) {
        if (!x.ok) {
          vehShowFlash(x.data.message || "Error.", "error");
          btn.disabled = false;
          btn.textContent = "Eliminar";
          return;
        }
        vehShowFlash("Asignación eliminada.", "success");
        var row = btn.closest("tr");
        if (row) row.remove();
      })
      .catch(function () {
        btn.disabled = false;
        btn.textContent = "Eliminar";
        vehShowFlash("Error de red.", "error");
      });
  };

