      equip.forEach(function (item) {
        var span = document.createElement("span");
        span.className =
          "inline-block px-2.5 py-0.5 rounded-full bg-emerald-100 text-emerald-800 text-xs font-medium";
        span.textContent = item;
        eqEl.appendChild(span);
